{
  "name": "footprint",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "predev": "yarn install && yarn build:packages",
    "dev": "turbo run dev --parallel --concurrency 50 --continue",
    "dev:storybook": "turbo run dev:storybook --concurrency 50",
    "build:packages": "turbo run build --filter=./packages/*",
    "format": "prettier --check \"**/*.{ts,tsx,md,mdx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:ci:bun": "turbo run test:ci:bun",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:stress:ci": "turbo run test:stress:ci",
    "test:watch": "turbo run test:watch",
    "preset:dot-env": "npx vercel login footprint",
    "set:dot-env": "turbo run set:dot-env",
    "pull:env": "npx vercel link -y --scope footprint && npx vercel env pull",
    "build:storybook": "turbo run build:storybook",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "version": "changeset version",
    "release": "changeset publish",
    "start": "turbo run start"
  },
  "dependencies": {},
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "esbuild": "^0.19.5",
    "esbuild-jest": "^0.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "prettier": "^3.2.5",
    "turbo": "^1.13.3",
    "webpack": "^5.76.0"
  },
  "overrides": {
    "@onefootprint/e2e": {
      "xml2js": "^0.6.0"
    },
    "bifrost": {
      "@tensorflow/tfjs-core": {
        "node-fetch": "^2.6.7"
      }
    }
  },
  "resolutions": {
    "**/jimp/**/xml2js": "^0.6.0",
    "**/face-api.js/@tensorflow/tfjs-core/node-fetch": "^2.6.7",
    "@storybook/react-docgen-typescript-plugin": "1.0.6--canary.9.cd77847.0",
    "@types/react": "^18"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">= 16.0.0"
  },
  "packageManager": "yarn@1.22.15"
}