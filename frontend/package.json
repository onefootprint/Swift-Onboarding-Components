{
  "name": "footprint",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:bifrost": "turbo run build --scope=bifrost --no-deps --include-dependencies",
    "build:dashboard": "turbo run build --scope=dashboard --no-deps --include-dependencies",
    "build:identity-wallet": "turbo run build --scope=identity-wallet --no-deps --include-dependencies",
    "build:d2p-mobile": "turbo run build --scope=d2p-mobile --no-deps --include-dependencies",
    "build:ui": "turbo run build --scope=ui --no-deps --include-dependencies",
    "build:frontpage": "turbo run build --scope=frontpage --no-deps --include-dependencies",
    "build:demo": "turbo run build --scope=demo --no-deps --include-dependencies",
    "build:verify": "turbo run build --scope=verify --no-deps --include-dependencies",
    "build": "turbo run build",
    "predev": "yarn install",
    "dev": "turbo run dev --parallel",
    "format": "prettier --check \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "prepare": "husky install",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/jest": "^28.1.2",
    "esbuild": "^0.14.38",
    "esbuild-jest": "^0.5.0",
    "husky": "^8.0.1",
    "jest": "^28.1.1",
    "jest-environment-jsdom": "^28.0.1",
    "jest-watch-typeahead": "^1.1.0",
    "lint-staged": "^13.0.2",
    "msw": "^0.39.2",
    "prettier": "^2.7.1",
    "turbo": "latest",
    "webpack": "^5.72.0"
  },
  "lint-staged": {
    "*.{jsx,js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=14.0.0"
  },
  "packageManager": "yarn@1.22.15"
}
