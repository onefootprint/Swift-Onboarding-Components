{
  "name": "footprint",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:storybook": "turbo run build:storybook",
    "build": "turbo run build",
    "chromatic": "turbo run chromatic --dry-run",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:storybook": "turbo run dev:storybook --concurrency 50",
    "dev": "turbo run dev --parallel --concurrency 50 --continue",
    "lint:ci": "turbo run lint:ci",
    "lint": "turbo run lint",
    "predev": "pnpm install && pnpm build:packages",
    "preset:dot-env": "npx vercel login footprint",
    "pull:env": "npx vercel link -y --scope footprint && npx vercel env pull",
    "release": "changeset publish",
    "set:dot-env": "turbo run set:dot-env",
    "start": "turbo run start",
    "test:ci:bun": "turbo run test:ci:bun",
    "test:ci": "turbo run test:ci",
    "test:watch": "turbo run test:watch",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "upload:sourcemaps": "turbo run upload:sourcemaps",
    "version": "changeset version",
    "generate:openapi": "turbo run generate:openapi"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.26.2",
    "@datadog/datadog-ci": "^2.42.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "turbo": "^2.2.3",
    "webpack": "^5.94.0"
  },
  "overrides": {
    "@onefootprint/e2e": {
      "xml2js": "^0.6.0"
    },
    "bifrost": {
      "@tensorflow/tfjs-core": {
        "node-fetch": "^2.6.7"
      }
    }
  },
  "resolutions": {
    "@storybook/react-docgen-typescript-plugin": "1.0.6--canary.9.cd77847.0",
    "@types/react": "^18"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "packageManager": "pnpm@9.14.2"
}
