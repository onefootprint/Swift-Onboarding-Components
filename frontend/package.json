{
  "name": "footprint",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "predev": "yarn install && yarn build:packages",
    "dev": "turbo run dev --parallel --concurrency 50 --continue",
    "dev:storybook": "turbo run dev:storybook --concurrency 50",
    "build:packages": "turbo run build --filter=./packages/*",
    "format": "prettier --check \"**/*.{ts,tsx,md,mdx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:watch": "turbo run test:watch",
    "preset:dot-env": "npx vercel login footprint",
    "set:dot-env": "turbo run set:dot-env",
    "pull:env": "npx vercel link -y --scope footprint && npx vercel env pull",
    "build:storybook": "turbo run build:storybook",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "version": "changeset version",
    "release": "changeset publish",
    "start": "turbo run start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.24.3",
    "esbuild": "^0.15.18",
    "esbuild-jest": "^0.5.0",
    "husky": "^8.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-watch-typeahead": "^2.2.2",
    "lint-staged": "^13.1.0",
    "prettier": "^2.8.4",
    "start-server-and-test": "^1.15.2",
    "turbo": "^1.10.14",
    "webpack": "^5.76.0"
  },
  "resolutions": {
    "@onefootprint/e2e/jimp/@jimp/plugins/@jimp/plugin-print/load-bmfont/parse-bmfont-xml/xml2js": "0.6.0"
  },
  "lint-staged": {
    "*.{jsx,js,ts,tsx}": [
      "yarn format:fix"
    ],
    "*.json": [
      "yarn format:fix"
    ]
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">= 16.0.0"
  },
  "packageManager": "yarn@1.22.15"
}