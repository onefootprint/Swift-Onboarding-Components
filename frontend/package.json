{
  "name": "footprint",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev:storybook": "turbo run dev:storybook",
    "predev": "yarn install && yarn build:packages",
    "dev": "turbo run dev --parallel --continue",
    "build:packages": "turbo run build --filter=./packages/*",
    "format": "prettier --check \"**/*.{ts,tsx,md,mdx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "set:dot-env": "turbo run set:dot-env",
    "build:storybook": "turbo run build:storybook",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "version": "changeset version",
    "release": "changeset publish",
    "start": "turbo run start",
    "start:demo": "turbo run start --filter=demo...",
    "start:bifrost": "turbo run start --filter=bifrost...",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:ci": "start-server-and-test start:bifrost http://localhost:3000 start:demo http://localhost:3002 test:e2e"
  },
  "devDependencies": {
    "@changesets/cli": "^2.24.3",
    "esbuild": "^0.15.18",
    "esbuild-jest": "^0.5.0",
    "husky": "^8.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.0",
    "jest-watch-typeahead": "^2.2.1",
    "lint-staged": "^13.1.0",
    "prettier": "^2.8.1",
    "start-server-and-test": "^1.15.2",
    "turbo": "1.6.3",
    "webpack": "^5.72.0"
  },
  "lint-staged": {
    "*.{jsx,js,ts,tsx}": [
      "yarn format:fix"
    ],
    "*.json": [
      "yarn format:fix"
    ]
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=16.0.0"
  },
  "packageManager": "yarn@1.22.15"
}