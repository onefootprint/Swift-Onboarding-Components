{
  "name": "frontpage",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true yarn build",
    "build": "next build",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "yarn i18n:copy-watch & next dev -p 3003",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -dep ui,request",
    "i18n:copy": "yarn i18n:copy-en",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3003",
    "typecheck": "yarn tsc --noEmit"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@intercom/messenger-js-sdk": "^0.0.11",
    "@lottiefiles/react-lottie-player": "^3.5.3",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@next/mdx": "^14.1.4",
    "@next/third-parties": "^14.2.4",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@tanstack/react-query": "^5.56.2",
    "@tryghost/content-api": "^1.11.20",
    "@typeform/embed": "^1.35.1",
    "@vercel/speed-insights": "^1.0.11",
    "axios": "^1.7.4",
    "cookies-next": "^4.1.1",
    "date-fns": "^3.4.0",
    "fathom-client": "^3.5.0",
    "framer-motion": "^7.8.0",
    "i18next": "^23.7.16",
    "i18next-locales-sync": "^2.0.1",
    "lodash": "^4.17.21",
    "next": "^14.2.4",
    "next-seo": "^6.5.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.2.1",
    "polished": "^4.2.2",
    "react": "^18",
    "react-country-flag": "^3.1.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^18",
    "react-hook-form": "^7.52.2",
    "react-i18next": "^14.0.0",
    "react-player": "^2.12.0",
    "react-swipeable": "^7.0.0",
    "react-syntax-highlighter": "^15.5.0",
    "styled-components": "^6",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@next/bundle-analyzer": "^12.3.4",
    "@next/mdx": "^14.1.4",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20",
    "@types/react-dom": "^18",
    "@types/tryghost__content-api": "^1.3.11",
    "@vercel/og": "^0.1.0",
    "copy-and-watch": "^0.1.6",
    "csstype": "^3.1.2",
    "next-compose-plugins": "^2.2.1",
    "tsconfig": "*",
    "typescript": "^5.5.2"
  }
}
