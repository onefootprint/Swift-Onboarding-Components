{
  "name": "partners",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build:analyze": "ANALYZE=true yarn build",
    "build": "next build",
    "dev": "next dev -p 3012",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -dep ui",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3012",
    "test:ci:bun": "bun test --bail",
    "test:watch": "DEBUG_PRINT_LIMIT=100000 bun test --watch",
    "test": "bun test",
    "typecheck": "yarn tsc --noEmit"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-navigation-menu": "1.0.0",
    "i18next": "^23.10.1",
    "i18next-resources-to-backend": "^1.2.0",
    "next": "^14.2.4",
    "next-i18n-router": "^5.3.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "7.47.0",
    "react-i18next": "^14.1.0",
    "styled-components": "^6",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^14.7.1",
    "@next/bundle-analyzer": "^14.1.0",
    "@onefootprint/types": "*",
    "@testing-library/react": "^14.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "bun-types": "^1",
    "msw": "^2.2.13",
    "typescript": "^5.5.2"
  }
}
