    "i18next": "^23.16.0",
    "lodash": "^4.17.21",
    "next": "^14.2.12",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^15.0.3",
    "styled-components": "^6"
  },
  "devDependencies": {
