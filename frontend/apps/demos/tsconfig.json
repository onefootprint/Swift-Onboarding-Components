{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "global-constants": ["../../packages/global-constants/src/*"],
      "themes": ["../../packages/themes/src/*"],
      "ui": ["../../packages/ui/src/*"],
      "hooks": ["../../packages/hooks/src/*"],
      "@onefootprint/footprint": ["../../packages/footprint/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
