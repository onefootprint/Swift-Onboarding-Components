    "google-libphonenumber": "^3.2.31",
    "isemail": "^3.2.0",
    "lodash": "^4.17.21",
    "next": "13.1.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.42.0",
    "styled-components": "^5.3.6"
