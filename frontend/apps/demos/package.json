{
  "name": "demo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:https": "local-ssl-proxy --source 4005 --target 3002",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3002",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "vercel env pull",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@onefootprint/footprint-js": "*",
    "@onefootprint/footprint-react": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/ui": "*",
    "@tryghost/content-api": "^1.11.0",
    "next": "13.0.0",
    "polished": "^4.2.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "styled-components": "^5.3.6"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "@playwright/test": "^1.27.1",
    "@sentry/browser": "^6.19.7",
    "@tanstack/react-query": "^4.9.0",
    "@types/node": "^17.0.12",
    "@types/react-dom": "^18.0.6",
    "@types/styled-components": "^5.1.25",
    "@types/tryghost__content-api": "^1.3.11",
    "eslint-config-footprint": "*",
    "i18next": "^21.9.2",
    "local-ssl-proxy": "^1.3.0",
    "react-i18next": "^11.18.6",
    "tsconfig": "*",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}