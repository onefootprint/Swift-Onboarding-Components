{
	"name": "demos",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build:analyze": "ANALYZE=true yarn build",
		"build": "next build",
		"clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
		"dev": "yarn i18n:copy-watch & next dev -p 3002",
		"i18n:clean": "rm -rf ./public/locales/",
		"i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
		"i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep ui,request",
		"i18n:copy": "yarn i18n:copy-en",
		"lint:ci": "biome ci src",
		"lint": "biome check src --fix",
		"set:dot-env": "sh ../../scripts/set-dot-env.sh",
		"start": "next start -p 3002",
		"typecheck": "yarn tsc --noEmit"
	},
	"dependencies": {
		"@onefootprint/core": "*",
		"@onefootprint/design-tokens": "*",
		"@onefootprint/footprint-js": "*",
		"@onefootprint/footprint-react": "7.0.0-beta.9",
		"@onefootprint/postmate": "2.1.0",
		"@onefootprint/request": "*",
		"@onefootprint/types": "*",
		"@onefootprint/ui": "*",
		"google-libphonenumber": "^3.2.32",
		"i18next-locales-sync": "^2.0.1",
		"i18next": "^23.7.16",
		"isemail": "^3.2.0",
		"lodash": "^4.17.21",
		"next": "^14.2.4",
		"react-dom": "^18",
		"react-hook-form": "^7.47.0",
		"react-i18next": "^14.0.0",
		"react": "^18",
		"styled-components": "^6",
		"usehooks-ts": "^2.9.1"
	},
	"devDependencies": {
		"@tanstack/react-query": "^4.35.7",
		"@types/lodash": "^4.14.194",
		"@types/node": "^20",
		"@types/react-dom": "^18",
		"copy-and-watch": "^0.1.6",
		"tsconfig": "*",
		"typescript": "^5.5.2"
	}
}
