{
  "name": "auth",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "i18n:copy": "yarn i18n:copy-en",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep idv,ui,request",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:clean": "rm -rf ./public/locales/",
    "dev": "yarn i18n:copy-watch & next dev -p 3011",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3011",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@onefootprint/appearance": "*",
    "@onefootprint/core": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/idv": "*",
    "@onefootprint/postmate": "2.1.0",
    "@onefootprint/request": "*",
    "@onefootprint/ui": "*",
    "@tanstack/react-query": "^4.35.7",
    "@xstate/react": "^3.2.1",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-locales-sync": "^2.0.1",
    "lodash": "^4.17.21",
    "logrocket": "^5.0.1",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^14.0.0",
    "styled-components": "^6",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.1.0",
    "@onefootprint/types": "*",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18",
    "bun-types": "^1",
    "copy-and-watch": "^0.1.6",
    "encoding": "^0.1.13",
    "eslint-config-footprint": "*",
    "tsconfig": "*",
    "typescript": "^5"
  },
  "browser": {
    "fs": false
  }
}