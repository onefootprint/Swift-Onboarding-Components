{
  "name": "handoff",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true pnpm build",
    "build": "next build",
    "postbuild": "pnpm upload:sourcemaps",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "next dev --turbopack -p 3005",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3005",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "typecheck": "pnpm tsc --noEmit",
    "upload:sourcemaps": "sh ../../scripts/upload-sourcemaps.sh --service=handoff"
  },
  "dependencies": {
    "@onefootprint/appearance": "workspace:*",
    "@onefootprint/design-tokens": "workspace:*",
    "@onefootprint/dev-tools": "workspace:*",
    "@onefootprint/footprint-js": "workspace:*",
    "@onefootprint/global-constants": "workspace:*",
    "@onefootprint/hooks": "workspace:*",
    "@onefootprint/icons": "workspace:*",
    "@onefootprint/idv": "workspace:*",
    "@onefootprint/request": "workspace:*",
    "@onefootprint/types": "workspace:*",
    "@onefootprint/ui": "workspace:*",
    "@tanstack/react-query": "^5.56.2",
    "@xstate/react": "^3.2.1",
    "constate": "^3.3.2",
    "i18next": "^23.16.0",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "next": "15.1.2",
    "react": "^18",
    "react-dom": "^18",
    "react-error-boundary": "4.0.11",
    "react-i18next": "^15.0.3",
    "styled-components": "^6",
    "usehooks-ts": "2.16.0",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.1.2",
    "@onefootprint/tailwind-config": "workspace:^",
    "@types/google.maps": "^3.55.11",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1",
    "i18next-locales-sync": "^2.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsconfig": "workspace:*",
    "typescript": "^5.6.3"
  },
  "browser": {
    "fs": false
  }
}
