    "@onefootprint/icons": "*",
    "@onefootprint/idv": "*",
    "@onefootprint/request": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@tanstack/react-query": "^4.35.7",
    "@xstate/react": "^3.2.1",
    "constate": "^3.3.2",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "logrocket": "^5.0.1",
