    "lodash": "^4.17.21",
    "next": "13.0.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.40.0",
    "react-i18next": "^12.0.0",
    "styled-components": "^5.3.6",
