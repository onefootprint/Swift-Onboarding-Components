{
  "name": "bifrost",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true yarn build",
    "build": "next build",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "yarn i18n:copy-watch & next dev -p 3000",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -dep idv,ui,request",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -dep idv,ui,request",
    "i18n:sync": "../../scripts/i18n/i18n-sync.sh",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3000",
    "test:ci": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "test": "jest",
    "typecheck": "yarn tsc --noEmit",
    "upload:sourcemaps": "sh ../../scripts/upload-sourcemaps.sh --service=bifrost"
  },
  "dependencies": {
    "@onefootprint/appearance": "*",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/idv": "*",
    "@onefootprint/postmate": "2.1.2",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-slot": "^1.0.2",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-locales-sync": "^2.0.1",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "lodash": "^4.17.21",
    "next": "^14.2.12",
    "react": "^18",
    "react-dom": "^18",
    "react-error-boundary": "4.0.11",
    "react-i18next": "^14.0.0",
    "styled-components": "^6",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^13.4.19",
    "@onefootprint/test-utils": "*",
    "@tanstack/react-query": "^5.56.2",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20",
    "@types/react-dom": "^18",
    "@xstate/react": "^3.2.1",
    "constate": "^3.3.2",
    "copy-and-watch": "^0.1.6",
    "tsconfig": "*",
    "typescript": "^5.5.2"
  },
  "browser": {
    "fs": false
  }
}
