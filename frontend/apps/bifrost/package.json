    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.23.0",
    "@testing-library/react": "^13.4.0",
    "axios": "^1.2.1",
    "axios-case-converter": "^0.9.0",
    "base64url": "^3.0.1",
    "focus-trap-react": "^10.0.2",
    "google-libphonenumber": "^3.2.31",
    "isemail": "^3.2.0",
    "mockdate": "^3.0.5",
    "qrcode.react": "^3.0.2",
