{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "i18n-build": "copy-and-watch --clean ../../packages/ui/src/config/locales/en/ui.json ./src/config/locales/en/*.json ./public/locales/en/",
    "i18n-watch": "copy-and-watch --clean --watch ../../packages/ui/src/config/locales/en/ui.json ./src/config/locales/en/*.json ./public/locales/en/",
    "dev": "yarn i18n-watch & next dev -p 3009",
    "build": "yarn i18n-build && next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3009",
    "lint": "yarn i18n-build && eslint src --fix",
    "lint:ci": "yarn i18n-build && eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn i18n-build && yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf ./public/locales/",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.35.7",
    "@types/react-scroll": "^1.8.7",
    "@vercel/og": "^0.0.27",
    "cmdk": "^0.2.0",
    "framer-motion": "^10.11.2",
    "lodash": "^4.17.21",
    "markdown-to-jsx": "^7.1.8",
    "next": "13.5.3",
    "next-themes": "^0.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.47.0",
    "react-scroll": "^1.8.9",
    "reading-time": "^1.5.0",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "@types/lodash": "^4.14.194",
    "@types/node": "^17.0.12",
    "@types/react-dom": "^18.0.10",
    "eslint-config-footprint": "*",
    "glob": "^8.0.3",
    "gray-matter": "^4.0.3",
    "i18next": "^23.7.16",
    "react-i18next": "^14.0.0",
    "tsconfig": "*",
    "copy-and-watch": "^0.1.6",
    "typescript": "4.9.5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "moduleNameMapper": {
      "@/api-reference/(.*)": "<rootDir>/@/api-reference/$1"
    }
  }
}