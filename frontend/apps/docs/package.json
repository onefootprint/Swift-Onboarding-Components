{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "i18n:copy": "yarn i18n:copy-en",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep ui,request",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
    "i18n:clean": "rm -rf ./public/locales/",
    "dev": "yarn i18n:copy-watch & next dev -p 3009",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3009",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/footprint-react": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.35.7",
    "@vercel/og": "^0.0.27",
    "cmdk": "^0.2.0",
    "framer-motion": "^10.11.2",
    "i18next-locales-sync": "^2.0.1",
    "i18next": "^23.7.16",
    "lodash": "^4.17.21",
    "markdown-to-jsx": "^7.1.8",
    "next-themes": "^0.2.1",
    "next": "14.2.3",
    "react-dom": "^18",
    "react-hook-form": "^7.47.0",
    "react-i18next": "^14.0.0",
    "react-scroll": "^1.8.9",
    "react": "^18",
    "reading-time": "^1.5.0",
    "styled-components": "^6",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@onefootprint/jest-presets": "*",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20",
    "@types/react-dom": "^18",
    "@types/react-scroll": "^1.8.7",
    "copy-and-watch": "^0.1.6",
    "eslint-config-footprint": "*",
    "glob": "^8.0.3",
    "gray-matter": "^4.0.3",
    "tsconfig": "*",
    "typescript": "^5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "moduleNameMapper": {
      "@/api-reference/(.*)": "<rootDir>/@/api-reference/$1"
    }
  }
}