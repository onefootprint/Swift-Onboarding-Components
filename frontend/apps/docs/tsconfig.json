{
  "exclude": ["node_modules"],
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@/api-reference/*": ["./src/pages/api-reference/*"]
    }
  },
  "include": ["src", "next-env.d.ts"]
}
