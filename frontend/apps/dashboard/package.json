{
  "name": "dashboard",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3001",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-select": "^1.2.0",
    "@rive-app/react-canvas": "^3.0.35",
    "@sentry/browser": "^7.28.1",
    "@tanstack/react-query": "^4.26.0",
    "@tanstack/react-query-devtools": "^4.20.4",
    "@xstate/react": "^3.2.1",
    "axios": "^1.2.1",
    "constate": "^3.3.2",
    "csstype": "^3.1.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^9.0.1",
    "google-map-react": "^2.2.0",
    "i18next": "^22.0.4",
    "lodash": "^4.17.21",
    "next": "13.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.43.5",
    "react-i18next": "^12.0.0",
    "styled-components": "^5.3.8",
    "svix-react": "1.4.2",
    "ua-parser-js": "^1.0.33",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.35.1",
    "zustand": "^4.3.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@next/bundle-analyzer": "^12.3.4",
    "@onefootprint/jest-presets": "*",
    "@onefootprint/test-utils": "*",
    "@types/file-saver": "^2.0.5",
    "@types/google-map-react": "^2.1.7",
    "@types/lodash": "^4.14.191",
    "@types/node": "^17.0.12",
    "@types/react-dom": "^18.0.10",
    "@types/styled-components": "^5.1.26",
    "eslint-config-footprint": "*",
    "tsconfig": "*",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ],
    "moduleNameMapper": {
      "@/proxy-configs/(.*)": "<rootDir>/src/pages/developers/components/proxy-configs/$1"
    }
  }
}
