{
  "name": "dashboard",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true pnpm build",
    "build": "next build",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "next dev --turbopack -p 3001",
    "dev:storybook": "storybook dev -p 3100",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3001",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=9216 jest --watch",
    "test": "jest",
    "test:ci": "NODE_OPTIONS=--max-old-space-size=9216 jest --ci --bail --runInBand",
    "typecheck": "pnpm tsc --noEmit"
  },
  "dependencies": {
    "@datadog/browser-rum": "^5.20.0",
