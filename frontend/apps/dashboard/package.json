{
  "name": "dashboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "i18n:copy": "yarn i18n:copy-en",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep ui,request",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
    "i18n:clean": "rm -rf ./public/locales/",
    "dev": "yarn i18n:copy-watch & next dev --turbo -p 3001",
    "build": "NODE_OPTIONS=--max-old-space-size=9216 next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3001",
    "test": "NODE_OPTIONS=--max-old-space-size=9216 jest",
    "test:ci": "NODE_OPTIONS=--max-old-space-size=9216 jest --ci --bail --runInBand",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=9216 NODE_OPTIONS=--max-old-space-size=9216 jest --watch",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=9216 yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@ariakit/react": "^0.3.12",
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@googlemaps/js-api-loader": "^1.16.6",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-collapsible": "1.0.2",
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-navigation-menu": "1.0.0",
    "@radix-ui/react-popover": "1.0.3",
    "@radix-ui/react-select": "2.0.0",
    "@rive-app/react-canvas": "^3.0.53",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.35.7",
    "@tanstack/react-query-devtools": "^4.35.7",
    "@vercel/analytics": "^0.1.11",
    "@xstate/react": "^3.2.1",
    "axios": "^1.6.5",
    "blob-util": "^2.0.2",
    "cmdk": "^0.2.0",
    "constate": "^3.3.2",
    "csstype": "^3.1.2",
    "date-fns": "^3.4.0",
    "file-saver": "^2.0.5",
    "flat": "^5.0.2",
    "framer-motion": "^9.0.1",
    "google-map-react": "^2.2.1",
    "i18next": "^23.7.16",
    "i18next-locales-sync": "^2.0.1",
    "isemail": "^3.2.0",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "lodash": "^4.17.21",
    "mapbox-gl": "^3.3.0",
    "match-sorter": "^6.3.1",
    "next": "14.2.3",
    "next-themes": "^0.2.1",
    "react": "^18",
    "react-calendly": "^4.1.1",
    "react-dom": "^18",
    "react-error-boundary": "4.0.11",
    "react-hook-form": "^7.47.0",
    "react-i18next": "^14.0.0",
    "react-map-gl": "^7.1.7",
    "react-qr-code": "^2.0.12",
    "react-virtualized": "^9.22.5",
    "styled-components": "^6",
    "svix-react": "1.4.2",
    "ua-parser-js": "^1.0.33",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1",
    "zustand": "^4.3.2"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@faker-js/faker": "^7.6.0",
    "@next/bundle-analyzer": "^13.4.19",
    "@onefootprint/jest-presets": "*",
    "@onefootprint/test-utils": "*",
    "@types/file-saver": "^2.0.5",
    "@types/flat": "^5.0.2",
    "@types/google-map-react": "^2.1.7",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-virtualized": "^9.21.29",
    "@types/validator": "^13.11.9",
    "copy-and-watch": "^0.1.6",
    "eslint-config-footprint": "*",
    "tsconfig": "*",
    "typescript": "^5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ],
    "moduleNameMapper": {
      "@/proxy-configs/(.*)": "<rootDir>/src/pages/developers/components/proxy-configs/$1",
      "@/entities/(.*)": "<rootDir>/src/components/entities/$1",
      "@/entity/(.*)": "<rootDir>/src/components/entities/components/details/$1",
      "@/playbooks/(.*)": "<rootDir>/src/pages/playbooks/$1",
      "@/lists/(.*)": "<rootDir>/src/pages/lists/$1"
    }
  }
}