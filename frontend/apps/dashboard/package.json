{
  "name": "dashboard",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "i18n-build": "copy-and-watch --clean ../../packages/ui/src/config/locales/en/ui.json ./src/config/locales/en/*.json ./public/locales/en/",
    "i18n-watch": "copy-and-watch --clean --watch ../../packages/ui/src/config/locales/en/ui.json ./src/config/locales/en/*.json ./public/locales/en/",
    "dev": "yarn i18n-watch & next dev -p 3001",
    "build": "yarn i18n-build && next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3001",
    "test": "yarn i18n-build && jest",
    "test:ci": "yarn i18n-build && jest --ci --bail --runInBand",
    "test:watch": "yarn i18n-build && jest --watch",
    "lint": "yarn i18n-build && eslint src --fix",
    "lint:ci": "yarn i18n-build && eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn i18n-build && yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf ./public/locales/",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@ariakit/react": "^0.3.12",
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@rive-app/react-canvas": "^3.0.53",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.35.7",
    "@tanstack/react-query-devtools": "^4.35.7",
    "@types/flat": "^5.0.2",
    "@types/react-virtualized": "^9.21.29",
    "@vercel/analytics": "^0.1.11",
    "@xstate/react": "^3.2.1",
    "axios": "^1.6.5",
    "blob-util": "^2.0.2",
    "cmdk": "^0.2.0",
    "constate": "^3.3.2",
    "csstype": "^3.1.2",
    "date-fns": "^2.30.0",
    "file-saver": "^2.0.5",
    "flat": "^5.0.2",
    "framer-motion": "^9.0.1",
    "google-map-react": "^2.2.0",
    "lodash": "^4.17.21",
    "match-sorter": "^6.3.1",
    "next": "13.5.3",
    "next-themes": "^0.2.1",
    "react": "18.2.0",
    "react-calendly": "^4.1.1",
    "react-dom": "18.2.0",
    "react-error-boundary": "4.0.11",
    "react-hook-form": "^7.47.0",
    "react-qr-code": "^2.0.12",
    "react-virtualized": "^9.22.5",
    "svix-react": "1.4.2",
    "ua-parser-js": "^1.0.33",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1",
    "zustand": "^4.3.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@next/bundle-analyzer": "^13.4.19",
    "@onefootprint/jest-presets": "*",
    "@onefootprint/test-utils": "*",
    "@types/file-saver": "^2.0.5",
    "@types/flat": "^5.0.2",
    "@types/google-map-react": "^2.1.7",
    "@types/lodash": "^4.14.194",
    "@types/node": "^17.0.12",
    "@types/react-dom": "^18.0.10",
    "eslint-config-footprint": "*",
    "i18next": "^23.7.16",
    "react-i18next": "^14.0.0",
    "copy-and-watch": "^0.1.6",
    "tsconfig": "*",
    "typescript": "4.9.5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ],
    "moduleNameMapper": {
      "@/proxy-configs/(.*)": "<rootDir>/src/pages/developers/components/proxy-configs/$1",
      "@/entities/(.*)": "<rootDir>/src/components/entities/$1",
      "@/entity/(.*)": "<rootDir>/src/components/entities/components/details/$1",
      "@/playbooks/(.*)": "<rootDir>/src/pages/playbooks/$1"
    }
  }
}