{
  "exclude": ["node_modules"],
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@/proxy-configs/*": ["./src/pages/developers/components/proxy-configs/*"],
      "@/businesses/*": ["./src/pages/businesses/*"],
      "@/business/*": ["./src/pages/businesses/pages/details/*"],
    }
  },
  "include": ["src", "next-env.d.ts"]
}
