{
  "exclude": ["node_modules"],
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@/proxy-configs/*": ["./src/pages/developers/components/proxy-configs/*"],
      "@/entities/*": ["./src/components/entities/*"],
      "@/entity/*": ["./src/components/entities/components/details/*"],
    }
  },
  "include": ["src", "next-env.d.ts"]
}


