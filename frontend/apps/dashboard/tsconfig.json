{
  "extends": "tsconfig/nextjs.json",
  "exclude": ["node_modules"],
  "include": ["next-env.d.ts", "./src/**/*"],
  "files": [],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["google.maps", "jest", "../../styled.d.ts", "bun-types"],
    "paths": {
      "src/*": ["./src/*"],
      "@/proxy-configs/*": ["src/pages/proxy-configs/*"],
      "@/entities/*": ["./src/components/entities/*"],
      "@/entity/*": ["./src/components/entities/components/details/*"],
      "@/playbooks/*": ["./src/pages/playbooks/*"],
      "@/lists/*": ["./src/pages/lists/*"]
    }
  }
}
