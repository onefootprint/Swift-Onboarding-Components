        },
        "vaulting-rules": {
          "title": "Vaulting rules",
          "token": {
            "label": "Vault token",
            "placeholder": "custom.bank_account_number",
            "errors": {
              "required": "A vault token is required"
            }
          },
          "target": {
            "label": "Source",
            "placeholder": "bank.account_number",
            "errors": {
              "required": "A source is required"
            }
          }
        },
        "add-more": "Add another"
      },
      "upload-file": {
        "or": "or",
        "remove": "Remove file"
      }
    }
