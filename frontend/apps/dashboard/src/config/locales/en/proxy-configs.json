    "form": {
      "title": "Create vault proxy config",
      "basic-configuration": {
        "title": "Basic configuration",
        "name": {
          "label": "Name",
          "placeholder": "My vault proxy config",
          "errors": {
            "required": "Please enter a name"
          }
        },
        "url": {
          "label": "URL",
          "placeholder": "https://acme.com",
          "errors": {
            "required": "Please enter a url"
          }
        },
        "method": {
          "label": "HTTP Method",
          "placeholder": "Select a method",
          "errors": {
            "required": "Please enter a method"
          }
        },
        "access-reason": {
          "label": "Access reason",
          "placeholder": "Reason",
          "errors": {
            "required": "Please enter a reason"
          }
        }
      },
      "custom-header": {
        "title": "Custom header values",
        "name": {
          "label": "Name"
        },
        "value": {
          "label": "Value"
        },
        "secret": {
          "label": "Secret"
        },
        "remove": "Remove",
        "add-more": "Add another"
      },
      "client-identity": {
        "title": "Client certificate authentication (mTLS)",
        "certificate": {
          "label": "Certificate",
          "placeholder": "Paste blob",
          "cta": "Upload PEM file"
        },
        "key": {
          "label": "Key (Encrypted)",
          "placeholder": "Paste blob",
          "cta": "Upload PEM file"
        }
      },
      "pinned-server-certificates": {
        "title": "Pinned server certificates",
        "certificate": {
          "label": "Certificate",
          "placeholder": "Paste blob",
          "cta": "Upload PEM file"
        },
        "add-more": "Add another"
      },
      "ingress-vaulting": {
        "title": "Ingress vaulting",
        "content-type": {
          "placeholder": "Your content type",
