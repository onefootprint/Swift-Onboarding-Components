            "title": "Error disabling proxy config"
          }
        }
      },
      "feedback": {
        "success": {
          "title": "Proxy config updated",
          "description": "{{name}} proxy config has been updated."
        },
        "error": {
          "title": "Error updating proxy config"
        }
      }
    }
