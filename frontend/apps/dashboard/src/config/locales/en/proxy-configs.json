  "notifications": {
    "create": {
      "success": {
        "title": "Vault proxy configuration created",
        "description": "Vault Proxy config {{name}} was created successfully"
      },
      "error": {
        "title": "Error creating vault proxy configuration"
      }
    },
    "update": {
      "success": {
        "title": "Vault proxy configuration updated",
        "description": "Vault proxy configuration was updated successfully"
      },
      "error": {
        "title": "Error updating vault proxy configuration"
      }
    },
    "remove": {
      "success": {
        "title": "Vault proxy configuration removed",
        "description": "Vault Proxy config was removed successfully"
      },
      "error": {
        "title": "Error removing vault proxy configuration"
      }
    }
