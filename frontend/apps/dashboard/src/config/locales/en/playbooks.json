{
  "copy": {
    "title": "Copying playbook",
    "form": {
      "name": {
        "label": "Playbook name",
        "base": "{{name}} (copy)",
        "placeholder": "Playbook name",
        "errors": {
          "required": "Please enter a name for the Playbook."
        }
      },
      "target": {
        "label": "Target environment",
        "options": {
          "live": "Live",
          "sandbox": "Sandbox"
        },
        "hint": "You're not allowed to copy playbooks to the live environment."
      },
      "feedback": {
        "success": {
          "title": "Playbook copied successfully",
          "description": "Playbook copied in the {{mode}} environment.",
          "cta": "Go to copied playbook"
        },
        "mode": {
          "title": "Changed to {{mode}}",
          "description": "Given the playbook is in the {{mode}} environment, we've switched to this mode."
        }
      },
      "cancel": "Cancel",
      "cta": "Copy to target"
    }
  }
}