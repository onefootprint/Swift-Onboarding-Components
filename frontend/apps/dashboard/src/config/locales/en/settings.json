        "form": {
          "email": {
            "label": "Email address",
            "placeholder": "jane.doe@acme.com",
            "errors": {
              "required": "Please enter an email"
            }
          },
          "role": {
            "label": "Role",
            "placeholder": "Select",
            "errors": {
              "required": "Please select a role"
            }
          },
          "errors": {
            "invalid": "Please complete the fields above."
          }
        },
        "notification": {
          "success": {
            "title_one": "Invitation sent successfully.",
            "description_one": "The user will receive an email with instructions to join the organization.",
            "title_other": "Invitations sent successfully.",
            "description_other": "The users will receive an email with instructions to join the organization."
