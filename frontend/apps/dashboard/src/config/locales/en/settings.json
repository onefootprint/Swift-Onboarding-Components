    "billing": {
      "page-title": "Footprint | Settings - Billing",
      "meta-title": "Settings",
      "title": "Billing",
      "subtitle": "View your billing details for the current month",
      "table": {
        "header": {
          "description": "Description",
          "quantity": "Quantity",
          "unit-price": "Unit price",
          "amount": "Amount"
        },
        "aria-label": "Projected invoice",
