        "actions": {
          "aria-label": "Open actions for member {{email}}",
          "not-allowed": "You are not allowed to change teammates",
          "remove": {
            "cta": "Remove",
            "confirmation": {
              "title": "Remove team member",
              "description": "You're about to remove <b>{{name}}</b> from your team. Are you sure?"
            },
            "notification": {
              "success": {
                "title": "Team member removed",
                "description": "{{email}} has been removed from the team."
              },
              "error": {
                "title": "Error removing team member"
              }
