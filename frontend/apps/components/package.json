    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/idv-elements": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.28.1",
    "axios": "^1.2.1",
    "axios-case-converter": "^0.9.0",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^12.3.4",
    "@onefootprint/jest-presets": "*",
    "@tanstack/react-query": "^4.29.5",
    "@types/lodash": "^4.14.191",
    "@types/node": "^17.0.31",
    "@types/react-dom": "^18.0.10",
    "@types/styled-components": "^5.1.26",
    "react-error-boundary": "^3.1.4",
    "constate": "^3.3.2",
