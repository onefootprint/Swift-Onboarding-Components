{
  "name": "components",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true pnpm build",
    "build": "next build",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "pnpm i18n:copy-watch & next dev -p 3010",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep idv,ui,request",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3010",
    "test:ci": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "test": "jest",
    "typecheck": "pnpm tsc --noEmit"
  },
  "dependencies": {
    "@onefootprint/appearance": "workspace:*",
    "@onefootprint/core": "workspace:*",
    "@onefootprint/design-tokens": "workspace:*",
    "@onefootprint/footprint-js": "workspace:*",
    "@onefootprint/global-constants": "workspace:*",
    "@onefootprint/icons": "workspace:*",
    "@onefootprint/idv": "workspace:*",
    "@onefootprint/postmate": "2.1.2",
    "@onefootprint/request": "workspace:*",
    "@onefootprint/types": "workspace:*",
    "@onefootprint/ui": "workspace:*",
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.7.4",
    "constate": "^3.3.2",
    "creditcardutils": "^1.0.0",
    "date-fns": "^2.30.0",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.0.1",
    "next": "^14.2.12",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^14.0.0",
    "styled-components": "^6",
    "use-places-autocomplete": "^4.0.0",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^12.3.4",
    "@onefootprint/test-utils": "workspace:*",
    "@storybook/react": "^8.2.9",
    "@types/creditcardutils": "^1.0.0",
    "@types/google.maps": "^3.55.11",
    "@types/jest": "^29.5.1",
    "@types/node": "^20",
    "@types/react-dom": "^18",
    "@types/react": "^18",
    "copy-and-watch": "^0.1.6",
    "csstype": "^3.1.2",
    "jest": "^29.7.0",
    "next-router-mock": "^0.9.13",
    "tsconfig": "workspace:*",
    "tsup": "^6.5.0",
    "typescript": "^5.5.2"
  },
  "browser": {
    "fs": false
  }
}
