{
  "name": "components",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3010",
    "test": "jest --ci --bail --runInBand --passWithNoTests",
