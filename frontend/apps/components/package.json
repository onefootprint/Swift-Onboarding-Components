{
  "name": "components",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "i18n-build": "copy-and-watch --clean ../../packages/{ui,idv}/src/config/locales/en/*.json ./src/config/locales/en/*.json ./public/locales/en/",
    "i18n-watch": "copy-and-watch --clean --watch ../../packages/{ui,idv}/src/config/locales/en/*.json ./src/config/locales/en/*.json ./public/locales/en/",
    "dev": "yarn i18n-watch & next dev -p 3010",
    "build": "yarn i18n-build && next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3010",
    "test": "yarn i18n-build && jest",
    "test:ci": "yarn i18n-build && jest --ci --bail --runInBand",
    "test:watch": "yarn i18n-build && jest --watch",
    "lint": "yarn i18n-build && eslint src --fix",
    "lint:ci": "yarn i18n-build && eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn i18n-build && yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf ./public/locales/",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@onefootprint/appearance": "*",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/idv": "*",
    "@onefootprint/postmate": "2.1.0",
    "@onefootprint/request": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.29.5",
    "@types/react-dom": "^18.0.10",
    "@xstate/react": "^3.2.1",
    "axios": "^1.6.5",
    "axios-case-converter": "^1.1.0",
    "constate": "^3.3.2",
    "creditcardutils": "^1.0.0",
    "date-fns": "^2.30.0",
    "logrocket": "^5.0.1",
    "logrocket-react": "^5.0.1",
    "react-hook-form": "^7.47.0",
    "use-places-autocomplete": "^4.0.0",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^12.3.4",
    "@onefootprint/jest-presets": "*",
    "@types/logrocket-react": "^3.0.1",
    "@types/node": "^17.0.31",
    "@types/react-dom": "^18.0.10",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.0.1",
    "i18next-http-backend": "^2.2.1",
    "lodash": "^4.17.21",
    "next": "13.5.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^14.0.0",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "copy-and-watch": "^0.1.6",
    "typescript": "4.9.5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ]
  },
  "browser": {
    "fs": false
  }
}