{
  "name": "components",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -lng en -dep idv,ui,request",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:clean": "rm -rf ./public/locales/",
    "dev": "yarn i18n:copy-watch & next dev -p 3010",
    "build": "next build",
    "build:analyze": "ANALYZE=true yarn build",
    "start": "next start -p 3010",
    "test": "jest",
    "test:ci": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh"
  },
  "dependencies": {
    "@onefootprint/appearance": "*",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/idv": "*",
    "@onefootprint/postmate": "2.1.0",
    "@onefootprint/request": "*",
    "styled-components": "^6",
    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@sentry/nextjs": "^7.91.0",
    "@tanstack/react-query": "^4.29.5",
    "@xstate/react": "^3.2.1",
    "axios": "^1.6.5",
    "axios-case-converter": "^1.1.0",
    "constate": "^3.3.2",
    "creditcardutils": "^1.0.0",
    "date-fns": "^2.30.0",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.0.1",
    "i18next-locales-sync": "^2.0.1",
    "lodash": "^4.17.21",
    "logrocket": "^5.0.1",
    "logrocket-react": "^5.0.1",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.47.0",
    "react-i18next": "^14.0.0",
    "use-places-autocomplete": "^4.0.0",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@next/bundle-analyzer": "^12.3.4",
    "@onefootprint/jest-presets": "*",
    "@types/logrocket-react": "^3.0.1",
    "@types/node": "^20",
    "@types/react-dom": "^18",
    "copy-and-watch": "^0.1.6",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ]
  },
  "browser": {
    "fs": false
  }
}