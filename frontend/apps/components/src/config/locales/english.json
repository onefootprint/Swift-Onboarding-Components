{
  "global": {
    "errors": {}
  },
  "components": {
    "secure-form": {
      "section-title": {
        "card-information": "Card information",
        "billing-address": "Billing address"
      },
      "name": {
        "form": {
          "label": "Cardholder name",
          "placeholder": "Jane Doe",
          "error": "Name cannot be empty"
        }
      },
      "card": {
        "number": {
          "label": "Card number",
          "placeholder": "1234 5678 9012 3456",
          "error": "Card number cannot be empty"
        },
        "expiry": {
          "label": "Expiry date",
          "placeholder": "MM/YY",
          "error": "Expiry date cannot be empty",
          "is-past": "Date must be in the future"
        },
        "cvc": {
          "label": "CVC",
          "placeholder": "123",
          "error": "CVC cannot be empty"
        }
      },
      "address": {
        "form": {
          "address-line-1": {
            "label": "Address line 1",
            "placeholder": "Street and house number",
            "error": "Address cannot be empty and must be a residential address (e.g. cannot be a P.O. Box)"
          },
          "address-line-2": {
            "label": "Address line 2 (optional)",
            "placeholder": "Apartment, suite, etc."
          },
          "city": {
            "label": "City",
            "placeholder": "Brooklyn",
            "error": "City cannot be empty"
          },
          "state": {
            "label": "State",
            "placeholder": "Select",
            "error": "State cannot be empty"
          },
          "country": {
            "label": "Country",
            "placeholder": "Select",
            "error": "Country cannot be empty"
          },
          "zip": {
            "label": "Zip code",
            "placeholder": "11206",
            "error": "Zip code cannot be empty"
          }
        }
      },
      "form-dialog": {
        "loading-aria-label": "Loading",
        "secured-by-footprint": {
          "label": "Secured by Footprint"
        },
        "modal-header": {
          "close-aria-label": "Close"
        }
      },
      "buttons": {
        "save": "Save",
        "cancel": "Cancel"
      }
    }
  },
  "pages": {}
}