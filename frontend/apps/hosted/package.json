{
  "name": "hosted",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:analyze": "ANALYZE=true pnpm build",
    "build": "next build",
    "postbuild": "pnpm upload:sourcemaps",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "pnpm i18n:copy-watch & next dev -p 3004",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep idv,ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -dep idv,ui,request",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -dep idv,ui,request",
    "i18n:sync": "../../scripts/i18n/i18n-sync.sh",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "set:dot-env": "sh ../../scripts/set-dot-env.sh",
    "start": "next start -p 3004",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "typecheck": "pnpm tsc --noEmit",
    "upload:sourcemaps": "sh ../../scripts/upload-sourcemaps.sh --service=hosted"
  },
  "dependencies": {
    "@onefootprint/appearance": "workspace:*",
    "@onefootprint/design-tokens": "workspace:*",
    "@onefootprint/dev-tools": "workspace:*",
    "@onefootprint/footprint-js": "workspace:*",
    "@onefootprint/global-constants": "workspace:*",
    "@onefootprint/hooks": "workspace:*",
    "@onefootprint/icons": "workspace:*",
    "@onefootprint/idv": "workspace:*",
    "@onefootprint/request": "workspace:*",
    "@onefootprint/types": "workspace:*",
    "@onefootprint/ui": "workspace:*",
    "@radix-ui/react-select": "^2.0.0",
    "@tanstack/react-query": "^5.56.2",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-locales-sync": "^2.0.1",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "next": "^14.2.12",
    "react": "^18",
    "react-dom": "^18",
    "react-error-boundary": "4.0.11",
    "react-i18next": "^14.0.0",
    "styled-components": "^6",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@types/google.maps": "^3.55.11",
    "@happy-dom/global-registrator": "^14.7.1",
    "@next/bundle-analyzer": "^13.4.19",
    "@testing-library/react": "^14.3.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@xstate/react": "^3.2.1",
    "bun-types": "^1",
    "constate": "^3.3.2",
    "copy-and-watch": "^0.1.6",
    "tsconfig": "workspace:*",
    "typescript": "^5.5.2"
  },
  "browser": {
    "fs": false
  }
}
