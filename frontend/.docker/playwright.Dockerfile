ENV CI true
ENV PATH /e2e/node_modules/.bin:$PATH
ENV E2E_ACME_SECRET_API_KEY_DEV $E2E_ACME_SECRET_API_KEY_DEV 
ENV E2E_ACME_SECRET_API_KEY_PROD $E2E_ACME_SECRET_API_KEY_PROD 
