{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "public/dist/**"
      ],
      "env": [
        "API_BASE_URL",
        "BIFROST_URL",
        "FORCE_FOOTPRINT_JS_TO_USE_LOCAL",
        "GHOST_API_URL",
        "GHOST_CONTENT_API_KEY",
        "IS_LOCAL",
        "IS_VERCEL_ENV_DEV",
        "IS_VERCEL_ENV_PREV",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_FATHOM_TRACKING_CODE",
        "NEXT_PUBLIC_GOOGLE_MAPS_KEY",
        "NEXT_PUBLIC_LOCAL_HANDOFF_BASE_URL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_TENANT_KEY",
        "NEXT_PUBLIC_VERCEL_ENV",
        "NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF",
        "NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA",
        "NEXT_PUBLIC_VERCEL_URL",
        "NODE_ENV",
        "REVALIDATE_SECRET_TOKEN"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "start": {
      "dependsOn": [],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "build:storybook": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "storybook-static/**"
      ]
    },
    "format": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "dev:storybook": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "set:dot-env": {
      "cache": false
    }
  },
  "globalDependencies": [
    "tsconfig.json",
    ".env.*"
  ],
  "globalEnv": [
    "GITHUB_TOKEN"
  ]
}