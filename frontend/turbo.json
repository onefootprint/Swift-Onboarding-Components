{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "public/dist/**", "storybook-static/**"],
      "env": [
        "API_BASE_URL",
        "AUTH_URL",
        "BIFROST_URL",
        "CI",
        "COMPONENTS_URL",
        "DATADOG_API_KEY",
        "DEMO_FORM_AUTH_TOKEN",
        "DEMO_RENDER_AUTH_TOKEN",
        "E2E_ACME_SECRET_API_KEY_DEV",
        "E2E_ACME_SECRET_API_KEY_PROD",
        "E2E_BIFROST_BASE_URL",
        "E2E_COMPONENTS_BASE_URL",
        "E2E_DEMOS_BASE_URL",
        "E2E_SECRET_API_KEY_DEV",
        "FORCE_FOOTPRINT_COMPONENTS_JS_TO_USE_LOCAL",
        "FORCE_FOOTPRINT_JS_TO_USE_LOCAL",
        "GHOST_API_URL",
        "GHOST_CONTENT_API_KEY",
        "HANDOFF_BASE_URL",
        "IS_E2E",
        "IS_LOCAL",
        "IS_VERCEL_ENV_DEV",
        "IS_VERCEL_ENV_PREV",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_APP_CLIP_ENABLED",
        "NEXT_PUBLIC_DDOG_CLIENT_TOKEN_AUTH",
        "NEXT_PUBLIC_DDOG_CLIENT_TOKEN_BIFROST",
        "NEXT_PUBLIC_DDOG_CLIENT_TOKEN_COMPONENTS",
        "NEXT_PUBLIC_DDOG_CLIENT_TOKEN_HANDOFF",
        "NEXT_PUBLIC_DDOG_CLIENT_TOKEN_HOSTED",
        "NEXT_PUBLIC_DDOG_RUM_APPLICATION_AUTH",
        "NEXT_PUBLIC_DDOG_RUM_APPLICATION_BIFROST",
        "NEXT_PUBLIC_DDOG_RUM_APPLICATION_COMPONENTS",
        "NEXT_PUBLIC_DDOG_RUM_APPLICATION_HANDOFF",
        "NEXT_PUBLIC_DDOG_RUM_APPLICATION_HOSTED",
        "NEXT_PUBLIC_DDOG_RUM_PERCENTAGE",
        "NEXT_PUBLIC_E2E_TENANT_PK",
        "NEXT_PUBLIC_FATHOM_TRACKING_CODE",
        "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
        "NEXT_PUBLIC_GOOGLE_MAPS_KEY",
        "NEXT_PUBLIC_IS_DDOG_ENABLED",
        "NEXT_PUBLIC_KYB_KEY",
        "NEXT_PUBLIC_KYB_TENANT_KEY",
        "NEXT_PUBLIC_KYC_ID_DOC_TENANT_KEY",
        "NEXT_PUBLIC_KYC_KEY",
        "NEXT_PUBLIC_KYC_TENANT_KEY",
        "NEXT_PUBLIC_LAUNCH_DARKLY_CLIENT_SIDE_ID_DEV",
        "NEXT_PUBLIC_LAUNCH_DARKLY_CLIENT_SIDE_ID_PREVIEW",
        "NEXT_PUBLIC_LAUNCH_DARKLY_CLIENT_SIDE_ID_PROD",
        "NEXT_PUBLIC_LOCAL_HANDOFF_BASE_URL",
        "NEXT_PUBLIC_STATIC_URL",
        "NEXT_PUBLIC_TENANT_KEY",
        "NEXT_PUBLIC_UNIFY_API_KEY",
        "NEXT_PUBLIC_VERCEL_ENV",
        "NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF",
        "NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA",
        "NEXT_PUBLIC_VERCEL_URL",
        "NEXT_PUBLIC_MAP_BOX_TOKEN",
        "NODE_ENV",
        "npm_package_name",
        "REVALIDATE_SECRET_TOKEN",
        "SDK_VERSION",
        "SOURCE_MAPS_PUBLIC_STATIC_PATH"
      ]
    },
    "upload:sourcemaps": {
      "cache": false,
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:ci": {
      "dependsOn": ["^build"]
    },
    "test:ci:bun": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "start": {},
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:ci": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": []
    },
    "clean": {
      "cache": false,
      "dependsOn": []
    },
    "set:dot-env": {
      "cache": false
    },
    "build:storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "dev:storybook": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build:storybook"]
    },
    "chromatic": {
      "dependsOn": ["^build:storybook"]
    },
    "generate:openapi": {
      "cache": false
    }
  }
}
