{
  "name": "@onefootprint/footprint",
  "private": false,
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify",
    "dev": "tsup src/index.ts --format esm,cjs --watch --dts",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@types/postmate": "^1.5.2",
    "config": "*",
    "postmate": "^1.5.2",
    "tsconfig": "*",
    "tsup": "^6.2.2",
    "types": "*",
    "typescript": "^4.7.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
