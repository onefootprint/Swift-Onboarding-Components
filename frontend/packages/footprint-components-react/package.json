{
  "name": "@onefootprint/footprint-components-react",
  "private": false,
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/footprint-components-react.umd.js",
  "module": "./dist/footprint-components-react.js",
  "types": "./dist/footprint-components-react.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-components-react.js",
      "require": "./dist/footprint-components-react.umd.js",
      "types": "./dist/footprint-components-react.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification",
    "components",
    "pci"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "publish:local": "yarn && yarn build && yalc publish"
  },
  "devDependencies": {
    "@onefootprint/footprint-components-js": "*",
    "eslint-config-footprint": "*",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "4.9.5"
  },
  "peerDependencies": {
    "@onefootprint/footprint-components-js": ">=0.x",
    "react": "17 - 18",
    "react-dom": "17 - 18"
  },
  "publishConfig": {
    "access": "public"
  }
}