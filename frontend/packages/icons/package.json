{
  "name": "@onefootprint/icons",
  "private": true,
  "version": "1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify",
    "dev": "tsup src/index.ts --format esm,cjs --watch --dts",
    "lint": "eslint src --fix",
    "lint:fix": "eslint --fix \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "generate:icos": "node ./src/scripts/icos/generate.js",
    "generate:flags": "node ./src/scripts/flags/generate.js",
    "generate": "yarn generate:icos && yarn generate:flags && prettier --write \"./**/*.{ts,tsx,md}\" && eslint --fix \"./**/*.{ts,tsx,md}\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@svgr/core": "^6.2.1",
    "@svgr/plugin-jsx": "^6.2.1",
    "@svgr/plugin-prettier": "^6.1.2",
    "@svgr/plugin-svgo": "^6.2.0",
    "@types/glob": "^7.2.0",
    "@types/react-dom": "^18.0.6",
    "@types/styled-components": "^5.1.25",
    "csstype": "^3.1.0",
    "eslint-config-footprint": "*",
    "glob": "^8.0.3",
    "@onefootprint/jest-presets": "*",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "styled-components": "^5.3.5",
    "@onefootprint/themes": "*",
    "tsconfig": "*",
    "tsup": "^6.2.2",
    "typescript": "4.7.4"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}
