{
  "name": "@onefootprint/icons",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "lint:fix": "eslint --fix \"**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"./**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "generate:icos": "node ./src/scripts/icos/generate.js",
    "generate": "yarn generate:icos",
    "postgenerate": "yarn lint:fix && yarn format:fix",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/jest-presets": "*",
    "@svgr/core": "^6.2.1",
    "@svgr/plugin-jsx": "^6.2.1",
    "@svgr/plugin-prettier": "^6.1.2",
    "@svgr/plugin-svgo": "^6.2.0",
    "@types/glob": "^7.2.0",
    "@types/react-dom": "^18",
    "eslint-config-footprint": "*",
    "glob": "^8.0.3",
    "lodash": "^4.17.21",
    "react": "^18",
    "react-dom": "^18",
    "styled-components": "^6",
    "tsconfig": "*",
    "typescript": "^5"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}