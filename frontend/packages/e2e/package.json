{
  "name": "@onefootprint/e2e",
  "private": true,
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "install:playwright": "npx playwright install",
    "test:e2e:debug": "E2E_ACME_SECRET_API_KEY_DEV=sk_test_uD1EOsnwUDgmSsOt1mnLrGVxgDjF9ZJZ3c E2E_SECRET_API_KEY_DEV=sk_test_uD1EOsnwUDgmSsOt1mnLrGVxgDjF9ZJZ3c E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#debug\"",
    "test:e2e:generate": "npx playwright codegen http://localhost:3002/e2e?ob_key=pb_test_93aTD4UecayaQyKKRjLbIH&locale=es-MX",
    "test:e2e:real": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#real\"",
    "test:e2e:show-report": "npx playwright show-report",
    "test:e2e:trace": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --workers 16 --reporter=html --trace on --retries=0 -g \"#ci\"",
    "test:e2e:ui": "E2E_ACME_SECRET_API_KEY_DEV=sk_test_uD1EOsnwUDgmSsOt1mnLrGVxgDjF9ZJZ3c E2E_SECRET_API_KEY_DEV=sk_test_uD1EOsnwUDgmSsOt1mnLrGVxgDjF9ZJZ3c E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@playwright/test": "^1.47.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv": "^16.3.1",
    "typescript": "^5.6.3"
  }
}
