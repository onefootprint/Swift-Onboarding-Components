{
  "name": "@onefootprint/e2e",
  "private": true,
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "eslint src",
    "lint": "eslint src --fix",
    "postinstall": "npx playwright install",
    "test:e2e:ci": "npx playwright test -g \"#ci\"",
    "test:stress:ci": "npx playwright test -g \"#stress\"",
    "test:e2e:debug": "E2E_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#debug\"",
    "test:e2e:real": "E2E_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#real\"",
    "test:e2e": "E2E_BASE_URL=http://localhost:3002 npx playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@playwright/test": "^1.40.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.4.4",
    "eslint-config-footprint": "*",
    "typescript": "4.9.5"
  }
}
