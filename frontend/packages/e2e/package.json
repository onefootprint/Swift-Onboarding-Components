{
  "name": "@onefootprint/e2e",
  "private": true,
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "eslint src",
    "lint": "eslint src --fix",
    "postinstall": "npx playwright install",
    "test:e2e:auth-ci": "npx playwright test src/auth/ -g \"#ci\" --workers=10",
    "test:e2e:verify-ci": "npx playwright test src/verify/ -g \"#ci\" --workers=10",
    "test:e2e:form-ci": "npx playwright test src/form/ -g \"#ci\" --workers=10",
    "test:e2e:debug": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#debug\"",
    "test:e2e:generate": "npx playwright codegen http://localhost:3002/e2e?ob_key=ob_test_yHlPBcaJ6lnxwkkD1YLStx&locale=es-MX",
    "test:e2e:real": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --project chromium --debug -g \"#real\"",
    "test:e2e:trace": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --workers 16 --reporter=html --trace on --retries=0 -g \"#ci\"",
    "test:e2e:show-report": "npx playwright show-report",
    "test:e2e:ui": "E2E_DEMOS_BASE_URL=http://localhost:3002 npx playwright test --ui",
    "test:stress:ci": "npx playwright test -g \"#stress\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@playwright/test": "^1.43.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint-config-footprint": "*",
    "typescript": "^5"
  }
}