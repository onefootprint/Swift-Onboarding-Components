{
  "name": "@onefootprint/components",
  "private": false,
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/footprint-components.umd.js",
  "module": "./dist/footprint-components.js",
  "types": "./dist/footprint-components.d.ts",
  "exports": {
    ".": {
      "require": "./dist/footprint-components.umd.js",
      "import": "./dist/footprint-components.js",
      "types": "./dist/footprint-components.d.ts"
    },
    "./dist/footprint-components.css": {
      "import": "./dist/footprint-components.css",
      "require": "./dist/footprint-components.css"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification",
    "components",
    "pci"
  ],
  "scripts": {
    "test": "jest --ci --bail --passWithNoTests",
    "test:watch": "jest --watch",
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "lint:fix": "eslint --fix \"**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "publish:local": "yarn && yarn build && yalc publish",
    "dev:storybook": "start-storybook -p 3011",
    "build:storybook": "build-storybook"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/request": "*",
    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@types/react-dom": "^18.0.10",
    "axios": "^1.2.1",
    "axios-case-converter": "^0.9.0",
    "creditcardutils": "^1.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.12.16",
    "i18next": "^22.5.0",
    "i18next-browser-languagedetector": "^7.0.1",
    "i18next-http-backend": "^2.2.1",
    "next": "13.2.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.43.9",
    "react-i18next": "^12.3.1",
    "use-places-autocomplete": "^4.0.0",
    "usehooks-ts": "^2.9.1",
    "@sentry/nextjs": "^7.28.1",
    "@storybook/addon-actions": "^6.5.15",
    "@storybook/addon-essentials": "^6.5.15",
    "@storybook/addon-interactions": "^6.5.15",
    "@storybook/addon-links": "^6.5.15",
    "@storybook/builder-webpack5": "^6.5.15",
    "@storybook/manager-webpack5": "^6.5.15",
    "@storybook/react": "^6.5.15",
    "@storybook/testing-library": "^0.0.11",
    "storybook-react-i18next": "^2.0.1",
    "zoid": "^9.0.86",
    "@tanstack/react-query": "^4.29.19",
    "@xstate/react": "^3.2.1"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "csstype": "^3.1.1",
    "eslint-config-footprint": "*",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "4.9.5",
    "@types/react-dom": "^18.0.10",
    "constate": "^3.3.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ]
  }
}