{
  "name": "@onefootprint/core",
  "private": false,
  "type": "module",
  "version": "0.0.2",
  "main": "./dist/footprint-core.cjs",
  "module": "./dist/footprint-core.js",
  "unpkg": "./dist/footprint-core.js",
  "types": "./dist/footprint-core.d.ts",
  "sideEffects": false,
  "author": "Footprint",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsup --watch",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test --bail",
    "typecheck": "pnpm tsc --noEmit"
  },
  "dependencies": {
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^14.7.1",
    "@types/node": "^20",
    "bun-types": "^1.0.25",
    "tsconfig": "workspace:*",
    "tsup": "^6.5.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
