  "license": "MIT",
  "scripts": {
    "build:storybook": "storybook build --stats-json",
    "dev:storybook": "storybook dev -p 3100",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -dep ui,request",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -dep ui,request",
    "i18n:sync": "../../scripts/i18n/i18n-sync.sh",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "test:ci": "jest --ci --bail --runInBand",
    "test:storybook": "test-storybook --ci --url http://127.0.0.1:3100",
    "test:watch": "jest --watch",
    "test": "jest --passWithNoTests",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=9216 pnpm tsc --noEmit",
    "chromatic": "chromatic --exit-zero-on-changes --monorepo-root=../.."
