{
  "name": "@onefootprint/idv",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "scripts": {
    "lint:fix": "eslint --fix \"**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/idv-elements": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@tanstack/react-query": "^4.29.19",
    "@xstate/react": "^3.2.1",
    "constate": "^3.3.2",
    "i18next": "^22.5.0",
    "react-hook-form": "^7.43.9",
    "react-i18next": "^12.3.1",
    "react-use-measure": "^2.1.1",
    "styled-media-query": "^2.1.2",
    "usehooks-ts": "2.7.2",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "@onefootprint/test-utils": "*",
    "@rive-app/react-canvas": "^3.0.35",
    "@types/lodash": "^4.14.191",
    "eslint-config-footprint": "*",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsconfig": "*",
    "typescript": "4.9.5",
    "webpack": "*"
  },
  "peerDependencies": {
    "next": "13.x",
    "react": "18.x",
    "react-dom": "18.x"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/react-i18next-test.ts"
    ],
    "moduleNameMapper": {
      "@/identify/(.*)": "<rootDir>/src/pages/identify/$1"
    }
  }
}