{
  "name": "@onefootprint/idv",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "i18n:sync": "../../scripts/i18n/i18n-sync.sh",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh -dep ui,request",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch -dep ui,request",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en -dep ui,request",
    "i18n:clean": "rm -rf ./public/locales/",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.6",
    "@onefootprint/appearance": "*",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/dev-tools": "*",
    "@onefootprint/footprint-js": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/hooks": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/postmate": "2.1.0",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@radix-ui/react-select": "^2.0.0",
    "@sentry/nextjs": "^7.105.0",
    "@tanstack/react-query": "^4.35.7",
    "@xstate/react": "^3.2.1",
    "base64url": "^3.0.1",
    "browser-image-compression": "^2.0.0",
    "constate": "^3.3.2",
    "date-fns": "^2.30.0",
    "face-api.js": "^0.22.2",
    "focus-trap-react": "^10.2.1",
    "framer-motion": "^10.12.4",
    "google-libphonenumber": "^3.2.32",
    "heic2any": "^0.0.4",
    "isemail": "^3.2.0",
    "launchdarkly-react-client-sdk": "^3.0.9",
    "lodash": "^4.17.21",
    "logrocket": "^5.0.1",
    "logrocket-react": "^5.0.1",
    "opencv-react-ts": "^0.0.11",
    "react-error-boundary": "4.0.11",
    "react-hook-form": "^7.47.0",
    "react-image-file-resizer": "^0.4.8",
    "react-qr-code": "^2.0.12",
    "styled-components": "^6",
    "styled-media-query": "^2.1.2",
    "ua-parser-js": "^1.0.33",
    "use-places-autocomplete": "^4.0.0",
    "use-resize-observer": "^9.1.0",
    "usehooks-ts": "2.7.2",
    "xstate": "^4.37.1"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "@onefootprint/test-utils": "*",
    "@rive-app/react-canvas": "^3.0.35",
    "@types/lodash": "^4.14.194",
    "@types/logrocket-react": "^3.0.1",
    "@types/styled-components": "^5.1.26",
    "copy-and-watch": "^0.1.6",
    "eslint-config-footprint": "*",
    "i18next": "^23.7.16",
    "i18next-locales-sync": "^2.0.1",
    "jest-canvas-mock": "^2.5.0",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^14.0.0",
    "tsconfig": "*",
    "typescript": "^5",
    "webpack": "*"
  },
  "peerDependencies": {
    "next": "14.x",
    "react": "18.x",
    "react-dom": "18.x"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web",
    "setupFiles": [
      "<rootDir>/src/config/initializers/i18next-test.ts"
    ],
    "moduleNameMapper": {
      "@/investor-profile/(.*)": "<rootDir>/src/plugins/investor-profile/$1",
      "@/identify/(.*)": "<rootDir>/src/pages/identify/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/utils/tests/setupTests.js"
    ]
  }
}