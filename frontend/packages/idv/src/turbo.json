{
  "extends": ["//"],
  "pipeline": {
    "i18n:sync": {
      "outputs": ["./src/config/locales/**"]
    },
    "i18n:copy": {
      "outputs": ["public/locales/**"]
    },
    "i18n:copy-en": {
      "outputs": ["public/locales/**"]
    },
    "i18n:copy-watch": {
      "outputs": ["public/locales/**"]
    },
    "i18n:build": {
      "dependsOn": ["i18n:sync", "i18n:copy"]
    },
    "i18n:dev": {
      "dependsOn": ["i18n:sync", "i18n:copy-watch"]
    },
    "i18n:clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "i18n:build"]
    },
    "build:analyze": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:ci": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:ci": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["i18n:clean"]
    }
  }
}
