{
  "extends": "tsconfig/react-library.json",
  "include": [".", "./.storybook/*"],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "types": ["google.maps", "jest"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@/identify/*": ["src/pages/identify-deprecated/*"]
    }
  }
}
