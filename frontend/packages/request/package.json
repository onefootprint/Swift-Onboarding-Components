{
  "name": "@onefootprint/request",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "i18n:clean": "rm -rf ./public/locales/",
    "i18n:copy-en": "../../scripts/i18n/i18n-copy.sh -lng en",
    "i18n:copy-watch": "../../scripts/i18n/i18n-copy.sh --watch",
    "i18n:copy": "../../scripts/i18n/i18n-copy.sh",
    "i18n:sync": "../../scripts/i18n/i18n-sync.sh",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "test:ci:hidden": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "test": "jest",
    "typecheck": "pnpm tsc --noEmit"
  },
  "devDependencies": {
    "@onefootprint/dev-tools": "workspace:*",
    "@onefootprint/types": "workspace:*",
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^29.4.2",
    "@types/node": "^20",
    "axios": "^1.7.4",
    "axios-case-converter": "^1.1.0",
    "i18next": "^23.7.16",
    "i18next-locales-sync": "^2.0.1",
    "react-i18next": "^14.0.0",
    "copy-and-watch": "^0.1.6",
    "tsconfig": "workspace:*",
    "typescript": "^5.5.2"
  },
  "peerDependencies": {
    "axios": "^1.7.4",
    "axios-case-converter": "^1.1.0"
  },
  "jest": {
    "setupFiles": ["<rootDir>/src/config/initializers/i18next-test.ts"]
  }
}
