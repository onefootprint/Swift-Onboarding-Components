    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@types/ua-parser-js": "^0.7.36",
    "@types/react-dom": "^18.0.6",
    "config": "*",
    "global-constants": "*",
    "react-dom": "18.2.0",
    "react-i18next": "^11.16.9",
    "react": "18.2.0",
    "request": "*",
    "tsconfig": "*",
    "ui": "*",
    "tsup": "^6.2.2",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "ua-parser-js": "^1.0.2"
  }
}
