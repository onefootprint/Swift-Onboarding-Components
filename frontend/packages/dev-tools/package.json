{
  "name": "@onefootprint/dev-tools",
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "typecheck": "pnpm tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.0",
    "bun-types": "^1.0.25",
    "tsconfig": "workspace:*",
    "typescript": "^5.6.3"
  }
}
