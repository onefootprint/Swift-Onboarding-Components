{
  "name": "@onefootprint/footprint-js",
  "private": false,
  "version": "0.1.2",
  "main": "./dist/footprint-js.umd.js",
  "module": "./dist/footprint-js.esm.js",
  "types": "./dist/footprint-js.d.ts",
  "exports": {
    ".": {
      "require": "./dist/footprint-js.cjs.js",
      "import": "./dist/footprint-js.esm.js",
      "types": "./dist/footprint-js.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@types/postmate": "^1.5.2",
    "eslint-config-footprint": "*",
    "jest-presets": "*",
    "postmate": "^1.5.2",
    "tsconfig": "*",
    "tsup": "^6.2.2",
    "types": "*",
    "typescript": "^4.7.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "jest-presets/jest/web"
  }
}
