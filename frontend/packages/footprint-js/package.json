{
  "name": "@onefootprint/footprint-js",
  "private": false,
  "type": "module",
  "version": "3.4.0",
  "main": "./dist/footprint-js.cjs",
  "module": "./dist/footprint-js.js",
  "unpkg": "./dist/footprint-js.js",
  "types": "./dist/footprint-js.d.ts",
  "style": "./dist/footprint-js.css",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification"
  ],
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --bail --runInBand",
    "test:watch": "jest --watch",
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "publish:local": "yarn && yarn build && yalc publish"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "@onefootprint/postmate": "2.1.0",
    "csstype": "^3.1.1",
    "eslint-config-footprint": "*",
    "jest-fetch-mock": "^3.0.3",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "4.9.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}