{
  "name": "@onefootprint/footprint-js",
  "private": false,
  "type": "module",
  "version": "0.6.1",
  "main": "./dist/footprint-js.umd.js",
  "module": "./dist/footprint-js.js",
  "types": "./dist/footprint-js.d.ts",
  "exports": {
    ".": {
      "require": "./dist/footprint-js.umd.js",
      "import": "./dist/footprint-js.js",
      "types": "./dist/footprint-js.d.ts"
    },
    "./dist/footprint-js.css": {
      "import": "./dist/footprint-js.css",
      "require": "./dist/footprint-js.css"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification"
  ],
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@onefootprint/jest-presets": "*",
    "jest-fetch-mock": "^3.0.3",
    "@types/postmate": "^1.5.2",
    "csstype": "^3.1.1",
    "eslint-config-footprint": "*",
    "postmate": "^1.5.2",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "4.8.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}