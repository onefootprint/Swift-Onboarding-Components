    "@types/react-window": "^1.8.5",
    "@types/styled-components": "^5.1.25",
    "csstype": "^3.1.0",
    "eslint-config-footprint": "*",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "styled-components": "^5.3.5",
    "tsconfig": "*",
    "tsup": "^6.2.2",
    "typescript": "4.7.4",
    "webpack": "*"
  },
  "peerDependencies": {
    "polished": "4.x",
    "react": "18.x",
    "react-dom": "18.x",
    "styled-components": "5.x"
