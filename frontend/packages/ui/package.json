{
  "name": "@onefootprint/ui",
  "private": true,
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "i18n-en": "copy-and-watch --clean ./src/config/locales/en/ui.json ./public/locales/en/",
    "i18n-es": "copy-and-watch --clean ./src/config/locales/es/ui.json ./public/locales/es/",
    "i18n-build": "yarn i18n-en && yarn i18n-es",
    "build": "yarn i18n-build",
    "build:analyze": "yarn i18n-build && ANALYZE=true yarn build-storybook",
    "build:storybook": "yarn i18n-build && build-storybook",
    "test": "yarn i18n-en && jest --coverage --passWithNoTests",
    "test:ci": "yarn i18n-en && jest --ci --bail --runInBand",
    "test:watch": "yarn i18n-en && jest --watch",
    "lint": "yarn i18n-build && eslint src --fix",
    "lint:ci": "yarn i18n-build && eslint src",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "yarn i18n-build && yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf ./public/locales/",
    "dev:storybook": "start-storybook -p 3100"
  },
  "dependencies": {
    "@formkit/auto-animate": "^1.0.0-beta.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/jest-presets": "*",
    "@onefootprint/styled": "*",
    "@popperjs/core": "^2.11.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "1.0.0",
    "@radix-ui/react-scroll-area": "1.0.3",
    "@radix-ui/react-tabs": "1.0.2",
    "@radix-ui/react-tooltip": "1.0.5",
    "cleave.js": "https://github.com/3runo/cleave.js.git#8b5392cd87f19d200da68143f0ce81676b1733f9",
    "constate": "^3.3.2",
    "csstype": "^3.1.2",
    "downshift": "^6.1.7",
    "focus-trap-react": "^10.2.1",
    "framer-motion": "^10.5.0",
    "google-libphonenumber": "^3.2.32",
    "json2mq": "^0.2.0",
    "lodash": "^4.17.21",
    "react-day-picker": "8.3.0",
    "react-device-detect": "^2.2.3",
    "react-highlight-words": "^0.18.0",
    "react-hook-form": "^7.47.0",
    "react-merge-refs": "^1.1.0",
    "react-popper": "^2.3.0",
    "react-select": "^5.3.2",
    "react-syntax-highlighter": "^15.5.0",
    "react-window": "^1.8.7",
    "styled-media-query": "^2.1.2",
    "use-places-autocomplete": "^2.0.0",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^13.5.2",
    "@storybook/addon-actions": "^6.5.15",
    "@storybook/addon-essentials": "^6.5.15",
    "@storybook/addon-interactions": "^6.5.15",
    "@storybook/addon-links": "^6.5.15",
    "@storybook/builder-webpack5": "^6.5.15",
    "@storybook/manager-webpack5": "^6.5.15",
    "@storybook/react": "^6.5.15",
    "@storybook/testing-library": "^0.0.11",
    "@types/cleave.js": "^1.4.6",
    "@types/creditcardutils": "^1.0.0",
    "@types/google-libphonenumber": "^7.4.23",
    "@types/google.maps": "^3.51.0",
    "@types/json2mq": "^0.2.0",
    "@types/lodash": "^4.14.194",
    "@types/react-dom": "^18.0.10",
    "@types/react-highlight-words": "^0.16.4",
    "@types/react-syntax-highlighter": "^15.5.4",
    "@types/react-window": "^1.8.5",
    "@types/styled-components": "^5.1.26",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^14.0.0",
    "tsconfig": "*",
    "typescript": "4.9.5",
    "webpack": "*"
  },
  "peerDependencies": {
    "react": "18.x",
    "react-dom": "18.x"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}