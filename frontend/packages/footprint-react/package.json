{
  "name": "@onefootprint/footprint-react",
  "private": false,
  "type": "module",
  "version": "7.7.3",
  "main": "./dist/footprint-react.cjs",
  "module": "./dist/footprint-react.js",
  "unpkg": "./dist/footprint-react.js",
  "types": "./dist/footprint-react.d.ts",
  "style": "./dist/footprint-react.css",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "dev": "tsup --watch",
    "pretest:ci:bun": "cd ../footprint-js && bun run tsup",
    "publish:local": "yarn && yarn build && yalc publish",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test --bail",
    "typecheck": "yarn tsc --noEmit"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.3.8",
    "@onefootprint/core": "*",
    "@onefootprint/footprint-js": "*",
    "@testing-library/react": "^14.2.1",
    "@types/classnames": "^2.3.1",
    "@types/cleave.js": "^1.4.6",
    "bun-types": "^1.0.26",
    "react": "^18",
    "react-dom": "^18",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "cleave.js": "https://github.com/3runo/cleave.js.git#8b5392cd87f19d200da68143f0ce81676b1733f9",
    "csstype": "^3.1.2",
    "i18next": "^23.16.0",
    "lodash": "^4.17.21",
    "react-hook-form": "^7.52.2"
  },
  "peerDependencies": {
    "@onefootprint/footprint-js": ">=3.15.2",
    "react": "17 - 18",
    "react-dom": "17 - 18"
  },
  "publishConfig": {
    "access": "public"
  }
}
