{
  "name": "@onefootprint/footprint-react",
  "private": false,
  "type": "module",
  "version": "0.0.2",
  "main": "./dist/footprint-react.umd.cjs",
  "module": "./dist/footprint-react.js",
  "types": "./dist/footprint-react.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-react.js",
      "require": "./dist/footprint-react.umd.cjs",
      "types": "./dist/footprint-react.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "yarn typecheck && vite build",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@onefootprint/footprint-js": "*",
    "@onefootprint/jest-presets": "*",
    "@onefootprint/types": "*",
    "eslint-config-footprint": "*",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsconfig": "*",
    "typescript": "4.8.4",
    "vite": "^3.1.7",
    "vite-plugin-dts": "^1.6.5"
  },
  "peerDependencies": {
    "react": "17 - 18",
    "react-dom": "17 - 18",
    "@onefootprint/footprint-js": ">= 0.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "@onefootprint/jest-presets/jest/web"
  }
}
