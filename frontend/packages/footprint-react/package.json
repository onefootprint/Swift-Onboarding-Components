{
  "name": "@onefootprint/footprint-react",
  "private": false,
  "type": "module",
  "version": "1.0.0",
  "main": "./dist/footprint-react.umd.js",
  "module": "./dist/footprint-react.js",
  "types": "./dist/footprint-react.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-react.js",
      "require": "./dist/footprint-react.umd.js",
      "types": "./dist/footprint-react.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@onefootprint/footprint-js": "*",
    "eslint-config-footprint": "*",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "4.8.4"
  },
  "peerDependencies": {
    "@onefootprint/footprint-js": ">=0.5.0",
    "react": "17 - 18",
    "react-dom": "17 - 18"
  },
  "publishConfig": {
    "access": "public"
  }
}