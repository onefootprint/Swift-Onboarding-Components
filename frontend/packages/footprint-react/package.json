{
  "name": "@onefootprint/footprint-react",
  "private": false,
  "type": "module",
  "version": "9.0.0",
  "main": "./dist/footprint-react.cjs",
  "module": "./dist/footprint-react.js",
  "unpkg": "./dist/footprint-react.js",
  "types": "./dist/footprint-react.d.ts",
  "style": "./dist/footprint-react.css",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint:ci": "biome ci src",
    "lint": "biome check src --fix --unsafe",
    "dev": "tsup --watch",
    "pretest:ci:bun": "cd ../footprint-js && bun run tsup",
    "publish:local": "pnpm && pnpm build && yalc publish",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "test": "bun test --bail",
    "typecheck": "pnpm tsc --noEmit"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.3.8",
    "@onefootprint/core": "workspace:*",
    "@onefootprint/fetch": "workspace:*",
    "@onefootprint/footprint-js": "workspace:*",
    "@onefootprint/request-types": "workspace:*",
    "@onefootprint/tailwind-config": "workspace:^",
    "@onefootprint/types": "workspace:*",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/cleave.js": "^1.4.6",
    "@types/lodash": "^4.14.202",
    "@types/react-dom": "^18",
    "@types/react": "^18",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.0.26",
    "postcss": "^8.4.47",
    "react-dom": "^18",
    "react": "^18",
    "tailwindcss": "^3.4.14",
    "tsconfig": "workspace:*",
    "tsup": "^6.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "cleave.js": "https://github.com/3runo/cleave.js.git#8b5392cd87f19d200da68143f0ce81676b1733f9",
    "clsx": "^2.0.0",
    "csstype": "^3.1.2",
    "i18next": "^23.16.0",
    "input-otp": "^1.4.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.460.0",
    "react-hook-form": "^7.52.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "peerDependencies": {
    "@onefootprint/footprint-js": ">=3.15.2",
    "react": "18 - 19",
    "react-dom": "18 - 19"
  },
  "publishConfig": {
    "access": "public"
  }
}
