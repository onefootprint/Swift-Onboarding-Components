{
  "name": "@onefootprint/footprint-react",
  "private": false,
  "type": "module",
  "version": "6.4.0",
  "main": "./dist/footprint-react.umd.js",
  "module": "./dist/footprint-react.js",
  "types": "./dist/footprint-react.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-react.js",
      "require": "./dist/footprint-react.umd.js",
      "types": "./dist/footprint-react.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test --bail",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "publish:local": "yarn && yarn build && yalc publish"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.3.8",
    "@onefootprint/footprint-js": "*",
    "@testing-library/react": "^14.2.1",
    "bun-types": "^1.0.26",
    "eslint-config-footprint": "*",
    "react": "^18",
    "react-dom": "^18",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@onefootprint/footprint-js": "3.10.0",
    "react": "17 - 18",
    "react-dom": "17 - 18"
  },
  "publishConfig": {
    "access": "public"
  }
}