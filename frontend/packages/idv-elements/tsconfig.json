{
  "extends": "tsconfig/react-library.json",
  "include": [".", "src"],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@/investor-profile/*": ["./src/plugins/investor-profile/*"],
    }
  },
}
