{
  "name": "@onefootprint/elements",
  "private": false,
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/footprint-elements.umd.js",
  "module": "./dist/footprint-elements.js",
  "types": "./dist/footprint-elements.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-elements.js",
      "require": "./dist/footprint-elements.umd.js",
      "types": "./dist/footprint-elements.d.ts"
    }
  },
  "sideEffects": false,
  "author": "Footprint",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "kyc",
    "identity verification"
  ],
  "scripts": {
    "test": "bun test --bail",
    "test:ci:bun": "bun test --bail",
    "test:watch": "bun test --watch",
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "typecheck": "yarn tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "publish:local": "yarn && yarn build && yalc publish"
  },
  "devDependencies": {
    "@onefootprint/footprint-js": "3.10.0",
    "@onefootprint/core": "*",
    "@onefootprint/types": "*",
    "@types/classnames": "^2.3.1",
    "@types/cleave.js": "^1.4.6",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20",
    "bun-types": "^1.0.25",
    "cleave.js": "https://github.com/3runo/cleave.js.git#8b5392cd87f19d200da68143f0ce81676b1733f9",
    "eslint-config-footprint": "*",
    "react-dom": "^18",
    "react": "^18",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "cleave-zen": "^0.0.17",
    "csstype": "^3.1.2",
    "i18next": "^23.10.1",
    "lodash": "^4.17.21",
    "qrcode.react": "^3.1.0",
    "react-hook-form": "^7.47.0",
    "react-i18next": "^14.1.0"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "publishConfig": {
    "access": "public"
  }
}