{
  "name": "mobile",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "predev": "yarn install && yarn build:packages",
    "dev": "turbo run dev --concurrency 30 --continue",
    "dev:packages": "turbo run dev --filter=./packages/* dev --concurrency 30 --continue",
    "format:ci": "prettier --check \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "typecheck:ci": "turbo run typecheck",
    "build:packages": "turbo run build --filter=./packages/*"
  },
  "devDependencies": {
    "eslint-config-footprint": "*",
    "eslint": "^7.32.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "jest": "^29.7.0",
    "prettier": "^2.8.4",
    "turbo": "^1.13.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@1.22.15"
}