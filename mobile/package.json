{
  "name": "mobile",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "predev": "yarn install && yarn build:packages",
    "dev": "turbo run dev --concurrency 30 --continue",
    "dev:packages": "turbo run dev --filter=./packages/* dev --concurrency 30 --continue",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "lint:ci": "eslint src",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build:packages": "turbo run build --filter=./packages/*"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-footprint": "*",
    "prettier": "^2.8.4",
    "turbo": "^1.10.14",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-watch-typeahead": "^2.2.2"
  },
  "resolutions": {
    "@types/react": "^18.2.8",
    "react": "^18.2.0",
    "react-native": "^0.71.11"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@1.22.15"
}