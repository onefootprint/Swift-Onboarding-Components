{
  "name": "mobile",
  "private": true,
  "scripts": {
    "build:packages": "turbo run build --filter=./packages/*",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:packages": "turbo run dev --filter=./packages/* dev --concurrency 30 --continue",
    "dev": "turbo run dev --concurrency 30 --continue",
    "lint:ci": "turbo run lint",
    "lint": "turbo run lint",
    "predev": "yarn install && yarn build:packages",
    "test:ci": "turbo run test:ci",
    "test": "turbo run test",
    "typecheck:ci": "turbo run typecheck",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "jest": "^29.7.0",
    "turbo": "^1.13.3"
  },
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "yarn@1.22.15"
}
