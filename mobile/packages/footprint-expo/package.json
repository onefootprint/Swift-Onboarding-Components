{
  "name": "@onefootprint/footprint-expo",
  "private": false,
  "type": "module",
  "version": "1.1.1",
  "main": "./dist/footprint-expo.cjs",
  "module": "./dist/footprint-expo.js",
  "types": "./dist/footprint-expo.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-expo.js",
      "require": "./dist/footprint-expo.cjs",
      "types": "./dist/footprint-expo.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "lint": "eslint src --fix",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/react": "^18.2.8",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "csstype": "^3.1.2",
    "expo": "~48.0.18",
    "expo-linking": "^4.0.1",
    "expo-web-browser": "~12.1.1",
    "query-string": "^8.1.0",
    "react": "^18.2.0",
    "react-native": "^0.71.10"
  },
  "peerDependencies": {
    "expo": "> 47",
    "react": "> 17",
    "react-native": ">= 0.70"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}