{
  "name": "@onefootprint/idv-elements",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --external react",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "tsup src/index.ts --format esm,cjs --watch --external react",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch",
    "typecheck": "yarn tsc --noEmit"
  },
  "devDependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/test-utils": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.2.8",
    "@types/styled-components": "^5.1.26",
    "jest-expo": "^48.0.2",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/ui": "*",
    "lodash": "^4.17.21",
    "react-native-safe-area-context": "^4.5.1",
    "react-native": "^0.71.7",
    "react": "^18.2.0",
    "usehooks-ts": "^2.9.1"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}