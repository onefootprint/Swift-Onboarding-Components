{
  "name": "@onefootprint/design-tokens",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "exports": {
    ".": {
      "require": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --external react react-native",
    "dev": "tsup src/index.ts --format esm,cjs --watch --external react react-native",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "format:fix": "prettier --write \"./**/*.{ts,tsx,md}\"",
    "lint:fix": "eslint --fix \"**/*.{ts,tsx,md}\"",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "typecheck": "yarn tsc --noEmit"
  },
  "devDependencies": {
    "@types/color": "^3.0.3",
    "color": "^4.2.3",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "polished": "^4.2.2",
    "style-dictionary": "^3.7.1",
    "token-transformer": "^0.0.27",
    "typescript": "4.9.5"
  }
}