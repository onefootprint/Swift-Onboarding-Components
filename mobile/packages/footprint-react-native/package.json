{
  "name": "@onefootprint/footprint-react-native",
  "private": false,
  "type": "module",
  "version": "2.0.0-beta.3",
  "main": "./dist/footprint-react-native.cjs",
  "module": "./dist/footprint-react-native.js",
  "unpkg": "./dist/footprint-react-native.js",
  "types": "./dist/footprint-react-native.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "lint": "biome check src --fix",
    "lint:ci": "biome ci src",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "publish:local": "yarn build && yalc publish"
  },
  "devDependencies": {
    "@onefootprint/types": "*",
    "@types/react": "^18.2.8",
    "react": "^18.2.0",
    "react-native": "0.74.3",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "csstype": "^3.1.2",
    "lodash": "^4.17.21",
    "query-string": "^8.1.0",
    "react-hook-form": "^7.46.2",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "react-native-mask-input": "^1.2.3",
    "validator": "^13.12.0"
  },
  "peerDependencies": {
    "react": ">= 18",
    "react-native": ">= 0.70"
  },
  "publishConfig": {
    "access": "public"
  }
}
