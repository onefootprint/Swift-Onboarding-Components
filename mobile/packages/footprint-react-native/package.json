{
  "name": "@onefootprint/footprint-react-native",
  "private": false,
  "type": "module",
  "version": "1.6.4",
  "main": "./dist/footprint-react-native.cjs",
  "module": "./dist/footprint-react-native.js",
  "unpkg": "./dist/footprint-react-native.js",
  "types": "./dist/footprint-react-native.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "publish:local": "yarn build && yalc publish"
  },
  "devDependencies": {
    "@onefootprint/types": "*",
    "@types/react": "^18.2.8",
    "react-native": "0.71.15",
    "react": "^18.2.0",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "csstype": "^3.1.2",
    "query-string": "^8.1.0",
    "react-native-inappbrowser-reborn": "^3.7.0"
  },
  "peerDependencies": {
    "react": "> 17",
    "react-native": ">= 0.60"
  },
  "publishConfig": {
    "access": "public"
  }
}