{
  "name": "@onefootprint/footprint-react-native",
  "private": false,
  "type": "module",
  "version": "1.2.1",
  "main": "./dist/footprint-react-native.cjs",
  "module": "./dist/footprint-react-native.js",
  "types": "./dist/footprint-react-native.d.ts",
  "exports": {
    ".": {
      "import": "./dist/footprint-react-native.js",
      "require": "./dist/footprint-react-native.cjs",
      "types": "./dist/footprint-react-native.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.2.8",
    "react-native": "^0.71.10",
    "react": "^18.2.0",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "csstype": "^3.1.2",
    "query-string": "^8.1.0",
    "react-native-inappbrowser-reborn": "^3.7.0"
  },
  "peerDependencies": {
    "react": "> 17",
    "react-native": ">= 0.60"
  },
  "publishConfig": {
    "access": "public"
  }
}