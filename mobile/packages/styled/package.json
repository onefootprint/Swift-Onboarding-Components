    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "react": "^18.2.0",
    "react-native": "^0.71.7",
    "styled-components": "^5.3.8"
  }
}