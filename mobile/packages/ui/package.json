{
  "name": "@onefootprint/ui",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react react-native",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "tsup src/index.tsx --format esm,cjs --watch --dts --external react react-native",
    "lint": "eslint src --fix",
    "test:watch": "jest --watch",
    "typecheck": "yarn tsc --noEmit"
  },
  "devDependencies": {
    "@onefootprint/test-utils": "*",
    "@types/react": "^18.0.37",
    "@types/styled-components": "^5.1.26",
    "jest-expo": "^48.0.2",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/styled": "*",
    "react": "^18.2.0",
    "react-native": "^0.71.6",
    "react-native-safe-area-context": "^4.5.1",
    "styled-components": "^5.3.8"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}
