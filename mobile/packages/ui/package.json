{
  "name": "@onefootprint/ui",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react react-native react-native-reanimated",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "tsup src/index.tsx --format esm,cjs --watch --dts --external react react-native react-native-reanimated",
    "lint": "eslint src --fix",
    "test:watch": "jest --watch",
    "typecheck": "yarn tsc --noEmit"
  },
  "devDependencies": {
    "@onefootprint/types": "*",
    "@onefootprint/test-utils": "*",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.0.37",
    "@types/styled-components": "^5.1.26",
    "jest-expo": "^48.0.2",
    "tsconfig": "*",
    "tsup": "^6.5.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/styled": "*",
    "@shopify/flash-list": "1.4.0",
    "expo-haptics": "^12.2.1",
    "lodash": "^4.17.21",
    "react-merge-refs": "^1.1.0",
    "react-native-flash-message": "^0.4.1",
    "react-native-modal": "^13.0.1",
    "react-native-portalize": "^1.0.7",
    "react-native-reanimated": "~2.14.4",
    "react-native-safe-area-context": "^4.5.1",
    "react-native": "^0.71.6",
    "react": "^18.2.0",
    "styled-components": "^5.3.8",
    "usehooks-ts": "^2.9.1"
  },
  "peerDependencies": {
    "react": "18",
    "react-native": ">= 0.71.0",
    "react-native-reanimated": "2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}