{
  "name": "@onefootprint/my",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "postinstall": "cd ../.. && yarn build:packages",
    "android": "react-native run-android",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "react-native start --reset-cache",
    "ios": "react-native run-ios",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch --detectOpenHandles",
    "test": "jest --ci --bail --detectOpenHandles",
    "typecheck": "yarn tsc --noEmit",
    "testflight": "npx eas build -p ios --auto-submit --profile testflight",
    "appstore": "npx eas build -p ios --auto-submit",
    "start": "react-native start"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.5",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/styled": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@react-native-async-storage/async-storage": "1.17.11",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/native-stack": "^6.9.12",
    "@shopify/flash-list": "1.4.0",
    "@tanstack/react-query": "^4.32.5",
    "@xstate/react": "^3.2.1",
    "base64url": "^3.0.1",
    "buffer": "^6.0.3",
    "i18next": "^22.0.4",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-hook-form": "^7.45.2",
    "react-i18next": "^12.2.0",
    "react-native": "0.71.8",
    "react-native-passkey": "^2.0.0",
    "react-native-reanimated": "~2.14.4",
    "react-native-safe-area-context": "4.5.0",
    "react-native-screens": "~3.20.0",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "^13.9.0",
    "react-native-vision-camera": "^2.15.4",
    "url-parse": "^1.5.10",
    "vision-camera-plugin-document": "0.8.0",
    "vision-camera-plugin-face-detection": "0.10.1",
    "xstate": "^4.37.1",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@onefootprint/test-utils": "*",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.2.8",
    "@types/url-parse": "^1.4.8",
    "babel-plugin-module-resolver": "^5.0.0",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "jest-expo": "^48.0.2",
    "module-resolver": "^1.0.0",
    "react-native-dotenv": "^3.4.8",
    "reactotron-react-native": "^5.0.3"
  },
  "jest": {
    "testTimeout": 30000,
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}