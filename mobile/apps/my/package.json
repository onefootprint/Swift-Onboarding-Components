{
  "name": "@onefootprint/my",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "postinstall": "cd ../.. && yarn build:packages",
    "android": "react-native run-android",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "react-native start --reset-cache",
    "ios": "react-native run-ios",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch",
    "test": "jest --ci --bail",
    "test:ci": "jest --ci --bail --runInBand",
    "build:dev": "npx eas build -p ios --auto-submit --profile testflight",
    "build:prod": "npx eas build -p ios --auto-submit",
    "start": "react-native start"
  },
  "dependencies": {
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@react-native-async-storage/async-storage": "1.19.3",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-navigation/bottom-tabs": "^6.5.9",
    "@react-navigation/native": "^6.1.8",
    "@react-navigation/native-stack": "^6.9.14",
    "@sentry/react-native": "^5.10.0",
    "@shopify/flash-list": "1.6.1",
    "@tanstack/react-query": "^4.35.7",
    "@xstate/react": "^3.2.2",
    "base64url": "^3.0.1",
    "buffer": "^6.0.3",
    "i18next": "^23.7.18",
    "lodash": "^4.17.21",
    "mixpanel-react-native": "^2.4.0",
    "react": "18.2.0",
    "react-hook-form": "^7.46.2",
    "react-i18next": "^14.0.1",
    "react-native": "^0.71.19",
    "react-native-device-info": "^10.11.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-hole-view": "^3.0.0-alpha3",
    "react-native-passkey": "^2.1.1",
    "react-native-reanimated": "^3.5.4",
    "react-native-safe-area-context": "^4.7.2",
    "react-native-screens": "^3.25.0",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "^13.14.0",
    "react-native-vision-camera": "^3.8.2",
    "react-native-worklets-core": "^0.5.0",
    "styled-components": "6.1.1",
    "url-parse": "^1.5.10",
    "usehooks-ts": "^2.9.1",
    "xstate": "^4.38.3",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@onefootprint/test-utils": "*",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.2.8",
    "@types/url-parse": "^1.4.8",
    "babel-plugin-module-resolver": "5.0.0",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "jest-expo": "^48.0.2",
    "metro-react-native-babel-preset": "0.77.0",
    "module-resolver": "^1.0.0",
    "react-native-bundle-visualizer": "^3.1.3",
    "react-native-dotenv": "^3.4.8",
    "typescript": "^5.5.2"
  },
  "jest": {
    "testTimeout": 30000,
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}
