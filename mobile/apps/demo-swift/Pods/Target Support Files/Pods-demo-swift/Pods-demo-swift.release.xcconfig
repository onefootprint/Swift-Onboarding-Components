CLANG_CXX_LANGUAGE_STANDARD = c++11
CLANG_CXX_LIBRARY = libc++
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/../../../packages/verify-ios-sdk/Frameworks" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Footprint"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -ObjC -l"c++" -framework "CoreModules" -framework "DoubleConversion" -framework "FootprintIOS" -framework "Pods_FootprintIOS" -framework "RCTAnimation" -framework "RCTBlob" -framework "RCTImage" -framework "RCTLinking" -framework "RCTNetwork" -framework "RCTSettings" -framework "RCTText" -framework "RCTTypeSafety" -framework "RCTVibration" -framework "RNCAsyncStorage" -framework "RNDeviceInfo" -framework "RNFlashList" -framework "RNSVG" -framework "React" -framework "ReactCommon" -framework "React_Codegen" -framework "React_NativeModulesApple" -framework "React_RCTAppDelegate" -framework "React_debug" -framework "React_jsc" -framework "React_runtimescheduler" -framework "React_utils" -framework "SocketRocket" -framework "cxxreact" -framework "fmt" -framework "folly" -framework "glog" -framework "jsi" -framework "jsinspector" -framework "jsireact" -framework "logger" -framework "react_native_passkey" -framework "react_native_safe_area_context" -framework "react_native_splash_screen" -framework "reactperflogger" -framework "yoga"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
