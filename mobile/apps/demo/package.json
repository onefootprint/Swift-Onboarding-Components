{
  "name": "@onefootprint/demo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "android": "expo run:android",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "expo start --dev-client --clear",
    "ios": "expo run:ios",
    "lint": "eslint src --fix",
    "typecheck": "yarn tsc --noEmit",
    "testflight": "npx eas build -p ios --auto-submit --profile testflight",
    "appstore": "npx eas build -p ios --auto-submit"
  },
  "dependencies": {
    "react-native-safe-area-context": "4.5.0",
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@onefootprint/idv": "*",
    "expo": "~48.0.11",
    "expo-dev-client": "~2.2.1",
    "expo-font": "~11.1.1",
    "expo-haptics": "~12.2.1",
    "expo-linking": "~4.0.1",
    "expo-splash-screen": "~0.18.1",
    "expo-status-bar": "~1.4.4",
    "react": "18.2.0",
    "react-native": "0.71.7",
    "react-native-reanimated": "~2.14.4",
    "react-native-vision-camera": "^2.15.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "^18.0.37",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint-config-footprint": "*",
    "module-resolver": "^1.0.0",
    "react-native-dotenv": "^3.4.8"
