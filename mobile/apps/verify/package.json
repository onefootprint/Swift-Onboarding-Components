{
  "name": "@onefootprint/verify",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build:sdk": "sh scripts/build-sdk.sh",
    "android": "react-native run-android",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules",
    "dev": "react-native start --reset-cache",
    "ios": "react-native run-ios",
    "lint": "eslint src --fix",
    "lint:ci": "eslint src",
    "test:watch": "jest --watch",
    "test": "jest --ci --bail",
    "typecheck": "yarn tsc --noEmit",
    "testflight": "npx eas build -p ios --auto-submit --profile testflight",
    "appstore": "npx eas build -p ios --auto-submit",
    "start": "react-native start"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@onefootprint/design-tokens": "*",
    "@onefootprint/global-constants": "*",
    "@onefootprint/icons": "*",
    "@onefootprint/request": "*",
    "@onefootprint/types": "*",
    "@onefootprint/ui": "*",
    "@react-native-async-storage/async-storage": "1.19.3",
    "@react-native-clipboard/clipboard": "^1.12.1",
    "@shopify/flash-list": "1.6.1",
    "@tanstack/react-query": "^4.35.7",
    "@xstate/react": "^3.2.2",
    "buffer": "^6.0.3",
    "date-fns": "^2.30.0",
    "i18next": "^23.7.18",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-hook-form": "^7.46.2",
    "react-i18next": "^14.0.1",
    "react-native": "^0.71.15",
    "react-native-device-info": "^10.11.0",
    "react-native-safe-area-context": "^4.7.2",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "^13.14.0",
    "styled-components": "^6.1.1",
    "url-parse": "^1.5.10",
    "usehooks-ts": "^2.9.1",
    "validator": "^13.11.0",
    "xstate": "^4.38.3",
    "zod": "^3.22.4",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@onefootprint/test-utils": "*",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.2.8",
    "@types/url-parse": "^1.4.8",
    "@types/validator": "^13.11.7",
    "babel-plugin-module-resolver": "5.0.0",
    "csstype": "^3.1.2",
    "eslint-config-footprint": "*",
    "jest-expo": "^48.0.2",
    "metro-react-native-babel-preset": "0.73.10",
    "module-resolver": "^1.0.0",
    "react-native-bundle-visualizer": "^3.1.3",
    "react-native-dotenv": "^3.4.8",
    "tsconfig": "*",
    "typescript": "^5.5.2"
  },
  "jest": {
    "testTimeout": 30000,
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}