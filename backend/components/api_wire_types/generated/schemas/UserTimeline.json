{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserTimeline",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "event",
    "timestamp"
  ],
  "properties": {
    "event": {
      "tsType": "UserTimelineEvent"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "UserTimelineEvent": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "data_collected"
              ]
            },
            "data": {
              "tsType": "DataCollectedInfo"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "biometric_registered"
              ]
            },
            "data": {
              "tsType": "LivenessEvent"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "document_uploaded"
              ]
            },
            "data": {
              "type": "array",
              "items": [],
              "maxItems": 0,
              "minItems": 0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "onboarding_decision"
              ]
            },
            "data": {
              "tsType": "OnboardingDecision"
            }
          }
        }
      ]
    },
    "DataCollectedInfo": {
      "type": "object",
      "required": [
        "attributes"
      ],
      "properties": {
        "attributes": {
          "type": "array",
          "items": {
            "tsType": "CollectedDataOption"
          }
        }
      }
    },
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    },
    "LivenessEvent": {
      "description": "Describes a liveness event that took place",
      "type": "object",
      "required": [
        "insightEvent"
      ],
      "properties": {
        "insightEvent": {
          "tsType": "InsightEvent"
        }
      }
    },
    "InsightEvent": {
      "description": "Describes a device insight event with locations and IP of the event",
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "regionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "metroCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeZone": {
          "type": [
            "string",
            "null"
          ]
        },
        "userAgent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "OnboardingDecision": {
      "description": "Describes a liveness event that took place",
      "type": "object",
      "required": [
        "complianceStatus",
        "id",
        "source",
        "timestamp",
        "verificationStatus"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "verificationStatus": {
          "tsType": "VerificationStatus"
        },
        "complianceStatus": {
          "tsType": "ComplianceStatus"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "tsType": "DecisionSource"
        }
      }
    },
    "VerificationStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "failed",
        "manual_review",
        "verified"
      ]
    },
    "ComplianceStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "alerts",
        "compliant"
      ]
    },
    "DecisionSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "footprint"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "member"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "organization"
              ]
            },
            "member": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}