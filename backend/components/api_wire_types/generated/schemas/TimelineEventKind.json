{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimelineEventKind",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "attributes",
        "kind",
        "requirementId",
        "vendors"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "requirement_fulfilled"
          ]
        },
        "requirementId": {
          "type": "string"
        },
        "vendors": {
          "type": "array",
          "items": {
            "tsType": "Vendor"
          }
        },
        "attributes": {
          "description": "contains meta data about the event",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "object",
      "required": [
        "decisionId",
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "decision"
          ]
        },
        "decisionId": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "onboardingId"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "onboard"
          ]
        },
        "onboardingId": {
          "type": "string",
          "format": "uuid"
        }
      }
    }
  ],
  "definitions": {
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    }
  }
}