{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OnboardingDecision",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "complianceStatus",
    "id",
    "timestamp",
    "verificationStatus"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "verificationStatus": {
      "tsType": "VerificationStatus"
    },
    "complianceStatus": {
      "tsType": "ComplianceStatus"
    },
    "tenantUserId": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "VerificationStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "failed",
        "manual_review",
        "verified"
      ]
    },
    "ComplianceStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "alerts",
        "compliant"
      ]
    }
  }
}