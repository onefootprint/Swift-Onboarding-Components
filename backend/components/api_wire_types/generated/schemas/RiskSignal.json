{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskSignal",
  "description": "A risk event",
  "type": "object",
  "required": [
    "id",
    "level",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "level": {
      "tsType": "Severity"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "Severity": {
      "description": "Describes the severity of of a risk signal",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}