{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskSignal",
  "description": "A risk event",
  "type": "object",
  "required": [
    "description",
    "id",
    "onboardingDecisionId",
    "reasonCode",
    "scopes",
    "severity",
    "timestamp",
    "vendors"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "onboardingDecisionId": {
      "type": "string"
    },
    "reasonCode": {
      "tsType": "FootprintReasonCode"
    },
    "description": {
      "type": "string"
    },
    "severity": {
      "tsType": "SignalSeverity"
    },
    "scopes": {
      "type": "array",
      "items": {
        "tsType": "SignalScope"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "deactivatedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "vendors": {
      "type": "array",
      "items": {
        "tsType": "Vendor"
      }
    }
  },
  "definitions": {
    "FootprintReasonCode": {
      "type": "string",
      "enum": [
        "subject_deceased",
        "ssn_issued_prior_to_dob",
        "mobile_number",
        "corporate_email_domain",
        "ssn_does_not_match_within_tolerance",
        "last_name_does_not_match"
      ]
    },
    "SignalSeverity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "fraud"
      ]
    },
    "SignalScope": {
      "description": "Represents the granularity of data attributes that could be alerted on by a data vendor",
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn",
        "address",
        "street_address",
        "city",
        "state",
        "zip",
        "country",
        "email",
        "phone_number",
        "identity",
        "ip_address",
        "document"
      ]
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    }
  }
}