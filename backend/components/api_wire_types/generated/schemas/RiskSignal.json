{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskSignal",
  "description": "A risk event",
  "type": "object",
  "required": [
    "decisionId",
    "id",
    "note",
    "reasonCode",
    "severity",
    "timestamp",
    "vendors"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "decisionId": {
      "type": "string"
    },
    "reasonCode": {
      "type": "string"
    },
    "note": {
      "type": "string"
    },
    "severity": {
      "tsType": "RiskSeverity"
    },
    "vendors": {
      "type": "array",
      "items": {
        "tsType": "Vendor"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "RiskSeverity": {
      "description": "Describes the severity of of a risk signal",
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high"
      ]
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    }
  }
}