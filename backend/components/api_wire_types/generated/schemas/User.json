{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "id",
    "identityDataAttributes",
    "isPortable",
    "onboardings",
    "orderingId",
    "startTimestamp"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "isPortable": {
      "type": "boolean"
    },
    "identityDataAttributes": {
      "type": "array",
      "items": {
        "tsType": "DataAttribute"
      }
    },
    "startTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "onboardings": {
      "type": "array",
      "items": {
        "tsType": "Onboarding"
      }
    },
    "orderingId": {
      "type": "integer",
      "format": "int64"
    }
  },
  "definitions": {
    "DataAttribute": {
      "description": "The type of data attribute",
      "type": "string",
      "enum": [
        "first_name",
        "last_name",
        "dob",
        "ssn9",
        "address_line1",
        "address_line2",
        "city",
        "state",
        "zip",
        "country",
        "email",
        "phone_number",
        "ssn4"
      ]
    },
    "Onboarding": {
      "description": "Describes a liveness event that took place",
      "type": "object",
      "required": [
        "canAccessData",
        "canAccessDataAttributes",
        "canAccessIdentityDocumentImages",
        "configId",
        "id",
        "insightEvent",
        "isLivenessSkipped",
        "name",
        "status",
        "timestamp"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "configId": {
          "type": "string"
        },
        "status": {
          "tsType": "OnboardingStatus"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "isLivenessSkipped": {
          "type": "boolean"
        },
        "insightEvent": {
          "tsType": "InsightEvent"
        },
        "canAccessData": {
          "type": "array",
          "items": {
            "tsType": "CollectedDataOption"
          }
        },
        "canAccessDataAttributes": {
          "type": "array",
          "items": {
            "tsType": "DataAttribute"
          }
        },
        "canAccessIdentityDocumentImages": {
          "type": "boolean"
        },
        "latestDecision": {
          "anyOf": [
            {
              "tsType": "OnboardingDecision"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "OnboardingStatus": {
      "description": "The type of data attribute",
      "type": "string",
      "enum": [
        "new",
        "processing",
        "manual_review",
        "step_up_required",
        "verified",
        "failed"
      ]
    },
    "InsightEvent": {
      "description": "Describes a device insight event with locations and IP of the event",
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "regionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "metroCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeZone": {
          "type": [
            "string",
            "null"
          ]
        },
        "userAgent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    },
    "OnboardingDecision": {
      "description": "Describes a liveness event that took place",
      "type": "object",
      "required": [
        "complianceStatus",
        "id",
        "source",
        "timestamp",
        "verificationStatus"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "verificationStatus": {
          "tsType": "VerificationStatus"
        },
        "complianceStatus": {
          "tsType": "ComplianceStatus"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "tsType": "DecisionSource"
        }
      }
    },
    "VerificationStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "failed",
        "manual_review",
        "verified"
      ]
    },
    "ComplianceStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "alerts",
        "compliant"
      ]
    },
    "DecisionSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "footprint"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "member"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "organization"
              ]
            },
            "member": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}