{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "decisions",
    "footprintUserId",
    "identityDataAttributes",
    "isPortable",
    "onboardings",
    "orderingId",
    "requirements",
    "startTimestamp"
  ],
  "properties": {
    "footprintUserId": {
      "type": "string"
    },
    "identityDataAttributes": {
      "type": "array",
      "items": {
        "tsType": "DataAttribute"
      }
    },
    "startTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "orderingId": {
      "type": "integer",
      "format": "int64"
    },
    "requirements": {
      "type": "array",
      "items": {
        "tsType": "Requirement"
      }
    },
    "onboardings": {
      "type": "array",
      "items": {
        "tsType": "Onboarding"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "tsType": "Decision"
      }
    },
    "isPortable": {
      "type": "boolean"
    }
  },
  "definitions": {
    "DataAttribute": {
      "description": "The type of data attribute",
      "type": "string",
      "enum": [
        "first_name",
        "last_name",
        "dob",
        "ssn9",
        "address_line1",
        "address_line2",
        "city",
        "state",
        "zip",
        "country",
        "email",
        "phone_number",
        "ssn4"
      ]
    },
    "Requirement": {
      "type": "object",
      "required": [
        "fulfilledAt",
        "id",
        "initiator",
        "kind",
        "onboardingId",
        "riskSignalIds",
        "status",
        "vendors"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "onboardingId": {
          "type": "string",
          "format": "uuid"
        },
        "kind": {
          "tsType": "RequirementKind"
        },
        "initiator": {
          "tsType": "RequirementInitiator"
        },
        "status": {
          "tsType": "RequirementVerificationStatus"
        },
        "vendors": {
          "type": "array",
          "items": {
            "tsType": "Vendor"
          }
        },
        "riskSignalIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fulfilledAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "RequirementKind": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number",
        "identity_document",
        "liveness"
      ]
    },
    "RequirementInitiator": {
      "description": "Who initiated this requirement",
      "type": "string",
      "enum": [
        "footprint",
        "tenant",
        "step_up"
      ]
    },
    "RequirementVerificationStatus": {
      "type": "string",
      "enum": [
        "Failed",
        "Verified"
      ]
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    },
    "Onboarding": {
      "description": "Describes a liveness event that took place",
      "type": "object",
      "required": [
        "canAccessData",
        "canAccessDataAttributes",
        "canAccessIdentityDocumentImages",
        "complianceStatus",
        "configId",
        "decisionId",
        "id",
        "insightEvent",
        "isLivenessSkipped",
        "name",
        "timestamp",
        "verificationStatus"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "configId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "canAccessData": {
          "type": "array",
          "items": {
            "tsType": "CollectedDataOption"
          }
        },
        "canAccessDataAttributes": {
          "type": "array",
          "items": {
            "tsType": "DataAttribute"
          }
        },
        "canAccessIdentityDocumentImages": {
          "type": "boolean"
        },
        "insightEvent": {
          "tsType": "InsightEvent"
        },
        "isLivenessSkipped": {
          "type": "boolean"
        },
        "verificationStatus": {
          "tsType": "VerificationStatus"
        },
        "complianceStatus": {
          "tsType": "ComplianceStatus"
        },
        "decisionId": {
          "type": "string"
        }
      }
    },
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    },
    "InsightEvent": {
      "description": "Describes a device insight event with locations and IP of the event",
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "regionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "metroCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeZone": {
          "type": [
            "string",
            "null"
          ]
        },
        "userAgent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "VerificationStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "failed",
        "processing",
        "manual_review",
        "verified"
      ]
    },
    "ComplianceStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "alerts",
        "compliant"
      ]
    },
    "Decision": {
      "type": "object",
      "required": [
        "compliance_status",
        "id",
        "source",
        "timestamp",
        "verification_status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "verification_status": {
          "tsType": "VerificationStatus"
        },
        "compliance_status": {
          "tsType": "ComplianceStatus"
        },
        "source": {
          "tsType": "DecisionSource"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "DecisionSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "footprint"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "member"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "organization"
              ]
            },
            "member": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}