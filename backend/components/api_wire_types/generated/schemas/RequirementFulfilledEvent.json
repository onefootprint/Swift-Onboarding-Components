{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RequirementFulfilledEvent",
  "type": "object",
  "required": [
    "attributes",
    "requirementId",
    "vendors"
  ],
  "properties": {
    "requirementId": {
      "type": "string"
    },
    "vendors": {
      "type": "array",
      "items": {
        "tsType": "Vendor"
      }
    },
    "attributes": {
      "description": "contains meta data about the event",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    }
  }
}