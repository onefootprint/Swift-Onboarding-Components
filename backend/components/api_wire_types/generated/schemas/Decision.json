{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decision",
  "type": "object",
  "required": [
    "compliance_status",
    "id",
    "source",
    "timestamp",
    "verification_status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "verification_status": {
      "tsType": "VerificationStatus"
    },
    "compliance_status": {
      "tsType": "ComplianceStatus"
    },
    "source": {
      "tsType": "DecisionSource"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "VerificationStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "failed",
        "processing",
        "manual_review",
        "verified"
      ]
    },
    "ComplianceStatus": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "alerts",
        "compliant"
      ]
    },
    "DecisionSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "footprint"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "member"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "organization"
              ]
            },
            "member": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}