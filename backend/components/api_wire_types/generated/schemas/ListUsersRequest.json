    "footprint_user_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp_lte": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "timestamp_gte": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "definitions": {
    "KycStatus": {
      "description": "The type of data attribute",
      "type": "string",
