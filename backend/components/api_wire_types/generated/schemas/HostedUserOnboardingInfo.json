{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HostedUserOnboardingInfo",
  "description": "Describes an onboarding of a user vault to a tenant",
  "type": "object",
  "required": [
    "can_access_data",
    "insight_event",
    "name",
    "timestamp"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "insight_event": {
      "tsType": "InsightEvent"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "can_access_data": {
      "type": "array",
      "items": {
        "tsType": "CollectedDataOption"
      }
    }
  },
  "definitions": {
    "InsightEvent": {
      "description": "Describes a device insight event with locations and IP of the event",
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "regionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "metroCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeZone": {
          "type": [
            "string",
            "null"
          ]
        },
        "userAgent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    }
  }
}