{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Requirement",
  "type": "object",
  "required": [
    "fulfilledAt",
    "id",
    "initiator",
    "kind",
    "onboardingId",
    "riskSignalIds",
    "status",
    "vendors"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "onboardingId": {
      "type": "string",
      "format": "uuid"
    },
    "kind": {
      "tsType": "RequirementKind"
    },
    "initiator": {
      "tsType": "RequirementInitiator"
    },
    "status": {
      "tsType": "RequirementVerificationStatus"
    },
    "vendors": {
      "type": "array",
      "items": {
        "tsType": "Vendor"
      }
    },
    "riskSignalIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fulfilledAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "RequirementKind": {
      "description": "The type of requirement",
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number",
        "identity_document",
        "liveness"
      ]
    },
    "RequirementInitiator": {
      "description": "Who initiated this requirement",
      "type": "string",
      "enum": [
        "footprint",
        "tenant",
        "step_up"
      ]
    },
    "RequirementVerificationStatus": {
      "type": "string",
      "enum": [
        "Failed",
        "Verified"
      ]
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "footprint",
        "idology",
        "socure",
        "lexis_nexis",
        "experian",
        "twilio"
      ]
    }
  }
}