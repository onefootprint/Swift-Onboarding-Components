{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InsightEvent",
  "description": "Describes a device insight event with locations and IP of the event",
  "type": "object",
  "required": [
    "timestamp"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ipAddress": {
      "type": [
        "string",
        "null"
      ]
    },
    "city": {
      "type": [
        "string",
        "null"
      ]
    },
    "country": {
      "type": [
        "string",
        "null"
      ]
    },
    "region": {
      "type": [
        "string",
        "null"
      ]
    },
    "regionName": {
      "type": [
        "string",
        "null"
      ]
    },
    "latitude": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "longitude": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "metroCode": {
      "type": [
        "string",
        "null"
      ]
    },
    "postalCode": {
      "type": [
        "string",
        "null"
      ]
    },
    "timeZone": {
      "type": [
        "string",
        "null"
      ]
    },
    "userAgent": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}