{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TenantPermission",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "admin"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "onboarding_configuration"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "api_keys"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "audit_trail"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "org_settings"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "security_logs"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "users"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "decrypt_custom"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "attributes",
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "decrypt"
          ]
        },
        "attributes": {
          "type": "array",
          "items": {
            "tsType": "CollectedDataOption"
          }
        }
      }
    }
  ],
  "definitions": {
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    }
  }
}