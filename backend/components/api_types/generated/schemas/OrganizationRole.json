{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrganizationRole",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "createdAt",
    "id",
    "name",
    "permissions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "tsType": "TenantPermission"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "TenantPermission": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "admin"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "onboarding_configuration"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "api_keys"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "audit_trail"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "org_settings"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "security_logs"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "users"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "decrypt_custom"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "attributes",
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "decrypt"
              ]
            },
            "attributes": {
              "type": "array",
              "items": {
                "tsType": "CollectedDataOption"
              }
            }
          }
        }
      ]
    },
    "CollectedDataOption": {
      "type": "string",
      "enum": [
        "name",
        "dob",
        "ssn4",
        "ssn9",
        "full_address",
        "partial_address",
        "email",
        "phone_number"
      ]
    }
  }
}