{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecretApiKey",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "createdAt",
    "id",
    "isLive",
    "name",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "tsType": "ApiKeyStatus"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "key": {
      "type": [
        "string",
        "null"
      ]
    },
    "lastUsedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "isLive": {
      "type": "boolean"
    }
  },
  "definitions": {
    "ApiKeyStatus": {
      "type": "string",
      "enum": [
        "disabled",
        "enabled"
      ]
    }
  }
}