{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrganizationMember",
  "description": "Describes a liveness event that took place",
  "type": "object",
  "required": [
    "createdAt",
    "email",
    "id",
    "roleId",
    "roleName"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "lastLoginAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "roleName": {
      "type": "string"
    },
    "roleId": {
      "type": "string"
    }
  }
}