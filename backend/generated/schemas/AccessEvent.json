{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AccessEvent",
  "description": "Describes an audit event of a data access",
  "type": "object",
  "required": [
    "fpId",
    "kind",
    "orderingId",
    "principal",
    "targets",
    "tenantId",
    "timestamp"
  ],
  "properties": {
    "fpId": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "principal": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "orderingId": {
      "type": "integer",
      "format": "int64"
    },
    "insightEvent": {
      "anyOf": [
        {
          "tsType": "InsightEvent"
        },
        {
          "type": "null"
        }
      ]
    },
    "kind": {
      "tsType": "AccessEventKind"
    },
    "targets": {
      "type": "string"
    }
  },
  "definitions": {
    "InsightEvent": {
      "description": "Describes a device insight event with locations and IP of the event",
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "regionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "metroCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeZone": {
          "type": [
            "string",
            "null"
          ]
        },
        "userAgent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "AccessEventKind": {
      "description": "The type of data attribute",
      "type": "string",
      "enum": [
        "decrypt",
        "update",
        "delete"
      ]
    }
  }
}