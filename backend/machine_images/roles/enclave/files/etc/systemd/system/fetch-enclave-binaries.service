[Unit]
Description=fetch-enclave-binaries
After=network.target cloud-final.service
Wants=network-online.target cloud-final.service

[Service]
Type=oneshot
User=root
ExecStart="/usr/local/bin/fetch-enclave-binaries.sh"
EnvironmentFile=/etc/fetch-enclave-binaries.env
RemainAfterExit=yes
Restart=on-failure
SyslogIdentifier=fetch-enclave-binaries

[Install]
WantedBy=multi-user.target
