[Unit]
Description=tailscale-connect
After=network.target tailscaled.service cloud-final.service
Wants=network-online.target tailscaled.service cloud-final.service

[Service]
Type=oneshot
User=root
ExecStart="/usr/local/bin/tailscale-connect.sh"
EnvironmentFile=/etc/tailscale-connect.env
RemainAfterExit=yes
Restart=on-failure
SyslogIdentifier=tailscale-connect

[Install]
WantedBy=multi-user.target
